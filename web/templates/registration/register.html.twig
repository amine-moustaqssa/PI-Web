{% extends 'front/base_front.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container px-5">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card border-0 shadow rounded-3 overflow-hidden">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h2 class="fw-bolder">Créer un compte</h2>
                            <p class="lead fw-normal text-muted mb-0">Rejoignez Clinique 360</p>
                        </div>

                        {% for flash_error in app.flashes('verify_email_error') %}
                            <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
                        {% endfor %}

                        {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}

                            {{ form_errors(registrationForm) }}

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        {{ form_widget(registrationForm.nom, {'attr': {'class': 'form-control'}}) }}
                                        <label for="{{ registrationForm.nom.vars.id }}">Nom</label>
                                        {{ form_errors(registrationForm.nom) }}
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        {{ form_widget(registrationForm.prenom, {'attr': {'class': 'form-control'}}) }}
                                        <label for="{{ registrationForm.prenom.vars.id }}">Prénom</label>
                                        {{ form_errors(registrationForm.prenom) }}
                                    </div>
                                </div>
                            </div>

                            <div class="form-floating mb-3">
                                {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
                                <label for="{{ registrationForm.email.vars.id }}">Adresse email</label>
                                {{ form_errors(registrationForm.email) }}
                            </div>

                            <div class="form-floating mb-3">
                                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control'}}) }}
                                <label for="{{ registrationForm.plainPassword.vars.id }}">Mot de passe</label>
                                {{ form_errors(registrationForm.plainPassword) }}
                            </div>

                            <div class="row">
                                <div class="col-md-8">
                                    <div class="form-floating mb-3">
                                        {{ form_widget(registrationForm.adresse, {'attr': {'class': 'form-control', 'style': 'height: auto;'}}) }}
                                        <label for="{{ registrationForm.adresse.vars.id }}">Adresse <small class="text-muted">(optionnel)</small></label>
                                        {{ form_errors(registrationForm.adresse) }}
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating mb-3">
                                        {{ form_widget(registrationForm.codePostal, {'attr': {'class': 'form-control'}}) }}
                                        <label for="{{ registrationForm.codePostal.vars.id }}">Code postal</label>
                                        {{ form_errors(registrationForm.codePostal) }}
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="form-check">
                                    {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                                    <label class="form-check-label" for="{{ registrationForm.agreeTerms.vars.id }}">
                                        J'accepte les conditions d'utilisation
                                    </label>
                                    {{ form_errors(registrationForm.agreeTerms) }}
                                </div>
                            </div>

                            <div class="d-grid">
                                <button class="btn btn-primary btn-lg" type="submit">S'inscrire</button>
                            </div>

                            <div class="text-center mt-3">
                                <a href="{{ path('app_login') }}" class="small">Déjà un compte ? Connectez-vous</a>
                            </div>

                        {{ form_end(registrationForm) }}

                        <hr class="my-4">

                        <div class="d-grid">
                            <a href="{{ path('connect_google_start') }}" class="btn btn-outline-danger btn-lg d-flex align-items-center justify-content-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 48 48">
                                    <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/>
                                    <path fill="#FF3D00" d="m6.306 14.691 6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/>
                                    <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/>
                                    <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/>
                                </svg>
                                S'inscrire avec Google
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
