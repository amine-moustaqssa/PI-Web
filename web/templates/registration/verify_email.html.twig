{% extends 'front/base_front.html.twig' %}

{% block title %}Vérification email{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container px-5">
        <div class="row justify-content-center">
            <div class="col-lg-5">
                <div class="card border-0 shadow rounded-3 overflow-hidden">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="mb-3">
                                <i class="bi bi-envelope-check" style="font-size: 3rem; color: #4e73df;"></i>
                            </div>
                            <h2 class="fw-bolder">Vérifiez votre email</h2>
                            <p class="text-muted">
                                Un code de vérification a été envoyé à<br>
                                <strong>{{ email }}</strong>
                            </p>
                        </div>

                        {% for flash_message in app.flashes('success') %}
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                {{ flash_message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endfor %}

                        {% for flash_message in app.flashes('error') %}
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                {{ flash_message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endfor %}

                        <form method="post" action="{{ path('app_verify_email') }}">
                            <div class="mb-4">
                                <label for="verification_code" class="form-label fw-semibold">Code de vérification</label>
                                <input 
                                    type="text" 
                                    id="verification_code" 
                                    name="verification_code" 
                                    class="form-control form-control-lg text-center" 
                                    placeholder="000000"
                                    style="letter-spacing: 8px; font-size: 1.5rem; font-weight: 700;"
                                    autocomplete="one-time-code"
                                    inputmode="numeric"
                                    autofocus
                                >
                                <div class="form-text text-center mt-2">Entrez le code à 6 chiffres reçu par email</div>
                            </div>

                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-primary btn-lg">Vérifier</button>
                            </div>
                        </form>

                        <div class="text-center">
                            <p class="text-muted mb-1">Vous n'avez pas reçu le code ?</p>
                            <a href="{{ path('app_resend_verification') }}" class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-arrow-clockwise"></i> Renvoyer le code
                            </a>
                        </div>

                        <div class="text-center mt-3">
                            <a href="{{ path('app_register') }}" class="small text-muted">
                                <i class="bi bi-arrow-left"></i> Retour à l'inscription
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
