{{ form_start(form, {'attr': {'class': 'user', 'novalidate': 'novalidate', 'id': 'specialite_form'}}) }}
    
    <div class="row">
        {# Champ Nom #}
        <div class="col-md-12">
            <div class="form-group">
                <label class="small mb-1 font-weight-bold text-gray-700">Nom de la spécialité <span class="text-danger">*</span></label>
                <div class="input-group input-group-sm">
                    <div class="input-group-prepend">
                        <span class="input-group-text bg-primary text-white border-0"><i class="fas fa-heartbeat"></i></span>
                    </div>
                    {{ form_widget(form.nom, {'attr': {'class': 'form-control form-control-sm bg-light border-0 small', 'placeholder': 'Ex: Cardiologie'}}) }}
                </div>
                {{ form_errors(form.nom) }}
            </div>
        </div>
    </div>

    <div class="row">
        {# Champ Couleur #}
        <div class="col-md-12">
            <div class="form-group">
                <label class="small mb-1 font-weight-bold text-gray-700">Couleur (Optionnel)</label>
                <div class="input-group input-group-sm">
                    <div class="input-group-prepend">
                        <span class="input-group-text bg-info text-white border-0"><i class="fas fa-palette"></i></span>
                    </div>
                    {{ form_widget(form.couleur, {'attr': {'class': 'form-control form-control-sm bg-light border-0 small', 'placeholder': 'Ex: #FF5733 or Blue'}}) }}
                </div>
                <small class="form-text text-muted ml-1">Code hexadécimal ou nom de couleur.</small>
                {{ form_errors(form.couleur) }}
            </div>
        </div>
    </div>

    {# Champ Departement - Explicitly styled #}
    {% if form.departement is defined %}
    <div class="row">
        <div class="col-md-12">
            <div class="form-group">
                <label class="small mb-1 font-weight-bold text-gray-700">Département associé <span class="text-danger">*</span></label>
                <div class="input-group input-group-sm">
                    <div class="input-group-prepend">
                        <span class="input-group-text bg-warning text-white border-0"><i class="fas fa-building"></i></span>
                    </div>
                    {{ form_widget(form.departement, {'attr': {'class': 'form-control form-control-sm bg-light border-0 small'}}) }}
                </div>
                {{ form_errors(form.departement) }}
            </div>
        </div>
    </div>
    {% endif %}

    <hr class="my-4">
    
{{ form_end(form) }}