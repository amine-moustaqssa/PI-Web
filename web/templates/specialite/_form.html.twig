{{ form_start(form) }}
    <div class="form-group">
        <label class="font-weight-bold">Nom de la spécialité</label>
        {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.nom) }}
    </div>

    <div class="form-group">
        <label class="font-weight-bold">Couleur (Hex ou Nom)</label>
        {{ form_widget(form.couleur, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.couleur) }}
    </div>

    <hr>
    
    <button class="btn btn-success btn-icon-split">
        <span class="icon text-white-50"><i class="fas fa-check"></i></span>
        <span class="text">{{ button_label|default('Enregistrer') }}</span>
    </button>
{{ form_end(form) }}