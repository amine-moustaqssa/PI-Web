{% extends 'admin/base_admin.html.twig' %}

{% block title %}Modifier Spécialité{% endblock %}

{% block body %}
    <div class="container-fluid">
        {# Titre de la page #}
        <h1 class="h3 mb-4 text-gray-800">Modifier la spécialité</h1>

        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Édition : {{ specialite.nom|default('Spécialité') }}</h6>
            </div>
            <div class="card-body">
                
                {# 1. Le formulaire de modification #}
                <div class="mb-4">
                    {{ include('specialite/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
                </div>

                <hr class="sidebar-divider my-4">

                {# 2. Zone des actions (Retour et Supprimer) #}
                <div class="d-flex justify-content-between align-items-center">
                    
                    {# Bouton Retour #}
                    <a href="{{ path('app_specialite_index') }}" class="btn btn-secondary btn-icon-split">
                        <span class="icon text-white-50">
                            <i class="fas fa-arrow-left"></i>
                        </span>
                        <span class="text">Retour à la liste</span>
                    </a>

                    {# Formulaire de suppression (Bouton rouge) #}
                    <div>
                        {{ include('specialite/_delete_form.html.twig') }}
                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}