{# templates/admin/admin_rendez_vous/rendez_vous/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Supervision des Rendez-vous{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3"><i class="bi bi-calendar-check me-2"></i>Supervision des Rendez-vous</h1>
        <span class="badge bg-success text-white px-3 py-3">{{ rendez_vous|length }} rendez-vous listés</span>
    </div>

    {# Barre de recherche (Filtre Médecin/Patient) #}
    <div class="card shadow-sm mb-4 border-0">
        <div class="card-body bg-light">
            <form method="get" class="row g-2">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="q" class="form-control border-start-0" 
                               placeholder="Rechercher un médecin, une spécialité ou un patient..." 
                               value="{{ search_query }}">
                    </div>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-dark">Filtrer</button>
                </div>
            </form>
        </div>
    </div>

    {# Tableau des résultats #}
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Date et Heure</th>
                            <th>Patient</th>
                            <th>Type / Praticien</th>
                            <th>Motif</th>
                            <th class="text-center">Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for rdv in rendez_vous %}
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-primary">{{ rdv.dateDebut|date('d/m/Y') }}</div>
                                <small class="text-muted">{{ rdv.dateDebut|date('H:i') }} - {{ rdv.dateFin|date('H:i') }}</small>
                            </td>
                            <td>
                                <span class="text-uppercase fw-semibold">{{ rdv.profil.nom }}</span> {{ rdv.profil.prenom }}
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-info text-dark">{{ rdv.type }}</span>
                            </td>
                            <td>
                                {# Correction truncate sans extension #}
                                <small class="text-muted">
                                    {{ rdv.motif|length > 40 ? rdv.motif|slice(0, 40) ~ '...' : rdv.motif }}
                                </small>
                            </td>
                            <td class="text-center">
                                {% if rdv.statut == 'validé' or rdv.statut == 'TERMINE' %}
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>{{ rdv.statut|upper }}</span>
                                {% elseif rdv.statut == 'annulé' %}
                                    <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>ANNULÉ</span>
                                {% else %}
                                    <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>{{ rdv.statut|upper }}</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-inbox fs-1 text-muted d-block mb-2"></i>
                                <span class="text-muted">Aucun rendez-vous ne correspond à vos critères.</span>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}