{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion du Personnel{% endblock %}

{% block body %}

{# Page Heading #}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Gestion du Personnel</h1>
    <a href="{{ path('admin_personnel_new') }}" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
        <i class="fas fa-user-plus fa-sm text-white-50 mr-1"></i> Ajouter un personnel
    </a>
</div>

{# Stats Cards #}
<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Personnel</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">{{ personnels|length }}</div>
                </div>
                <i class="fas fa-users fa-2x text-gray-300"></i>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Avec niveau d'accès</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">
                        {{ personnels|filter(p => p.niveauAcces is not null and p.niveauAcces != '')|length }}
                    </div>
                </div>
                <i class="fas fa-shield-alt fa-2x text-gray-300"></i>
            </div>
        </div>
    </div>
</div>

{# Data Table Card #}
<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Liste du personnel</h6>
        <form method="get" class="d-flex" style="max-width: 350px;">
            <input type="text" name="q" class="form-control form-control-sm mr-2"
                   placeholder="Rechercher..." value="{{ search_query|default('') }}">
            <button type="submit" class="btn btn-sm btn-outline-primary">
                <i class="fas fa-search"></i>
            </button>
        </form>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle" id="personnelTable" width="100%" cellspacing="0">
                <thead class="bg-light">
                    <tr>
                        <th style="width: 5%;">#</th>
                        <th>Personnel</th>
                        <th>E-mail</th>
                        <th>Niveau d'accès</th>
                        <th>Adresse</th>
                        <th class="text-center" style="width: 15%;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for personnel in personnels %}
                    <tr>
                        <td class="text-muted small">{{ personnel.id }}</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center mr-3"
                                     style="width: 38px; height: 38px; font-size: 0.85rem; flex-shrink: 0;">
                                    {{ personnel.prenom|first|upper }}{{ personnel.nom|first|upper }}
                                </div>
                                <div>
                                    <div class="font-weight-bold text-gray-800">{{ personnel.prenom }} {{ personnel.nom }}</div>
                                    {% if personnel.codePostal %}
                                        <div class="small text-muted">CP : {{ personnel.codePostal }}</div>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        <td><span class="small">{{ personnel.email }}</span></td>
                        <td>
                            {% if personnel.niveauAcces %}
                                <span class="badge badge-info px-2 py-1">{{ personnel.niveauAcces }}</span>
                            {% else %}
                                <span class="text-muted small">Non défini</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if personnel.adresse %}
                                <span class="small">{{ personnel.adresse }}</span>
                            {% else %}
                                <span class="text-muted small">—</span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            <a href="{{ path('admin_personnel_show', {id: personnel.id}) }}"
                               class="btn btn-info btn-circle btn-sm" title="Détails">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a href="{{ path('admin_personnel_edit', {id: personnel.id}) }}"
                               class="btn btn-warning btn-circle btn-sm" title="Modifier">
                                <i class="fas fa-pen"></i>
                            </a>
                            <button class="btn btn-danger btn-circle btn-sm btn-delete-personnel"
                                    data-id="{{ personnel.id }}"
                                    data-name="{{ personnel.prenom }} {{ personnel.nom }}"
                                    title="Supprimer">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <i class="fas fa-users fa-3x text-gray-300 mb-3 d-block"></i>
                            <h6 class="text-gray-500">Aucun personnel trouvé</h6>
                            <a href="{{ path('admin_personnel_new') }}" class="btn btn-primary btn-sm mt-2">
                                <i class="fas fa-plus mr-1"></i> Ajouter un personnel
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{# Delete Confirmation Modal #}
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title font-weight-bold text-gray-800">Confirmer la suppression</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Fermer">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                Êtes-vous sûr de vouloir supprimer <strong id="deletePersonnelName"></strong> ?
                <br><small class="text-danger">Cette action est irréversible.</small>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                <form id="deleteForm" method="post">
                    <input type="hidden" name="_token" id="deleteToken">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash mr-1"></i> Supprimer
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function() {
            $('#personnelTable').DataTable({
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json"
                },
                pageLength: 10,
                searching: false,
                order: [[1, 'asc']]
            });

            $('.btn-delete-personnel').on('click', function() {
                var id = $(this).data('id');
                var name = $(this).data('name');
                $('#deletePersonnelName').text(name);
                $('#deleteForm').attr('action', '/admin/personnel/' + id + '/supprimer');
                $('#deleteToken').val('delete' + id);
                $('#deleteModal').modal('show');
            });
        });
    </script>
{% endblock %}
