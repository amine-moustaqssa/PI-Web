{% extends 'admin/base_admin.html.twig' %}

{% block title %}Modifier Constante Vitale{% endblock %}

{% block body %}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-heartbeat text-primary mr-2"></i> Modifier Constante Vitale
    </h1>
    {% if constante.consultationId %}
    <a href="{{ path('admin_constante_by_consultation', {'consultationId': constante.consultationId.id}) }}" class="btn btn-secondary btn-sm">
        <i class="fas fa-arrow-left mr-1"></i> Retour aux constantes
    </a>
    {% else %}
    <a href="{{ path('admin_constante_index') }}" class="btn btn-secondary btn-sm">
        <i class="fas fa-arrow-left mr-1"></i> Retour à la liste
    </a>
    {% endif %}
</div>

{% if constante.consultationId %}
<div class="alert alert-info">
    <i class="fas fa-info-circle mr-1"></i>
    <strong>Consultation #{{ constante.consultationId.id }}</strong>
    — {{ constante.consultationId.dateEffectuee ? constante.consultationId.dateEffectuee|date('Y-m-d H:i') : '' }}
    — Statut : {{ constante.consultationId.statut }}
</div>
{% endif %}

{{ include('admin/constante_vitale/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

<form method="post" action="{{ path('admin_constante_delete', {'id': constante.id}) }}" class="mt-3" onsubmit="return confirm('Voulez-vous vraiment supprimer cette constante ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ constante.id) }}">
    <button class="btn btn-danger">
        <i class="fas fa-trash mr-1"></i> Supprimer
    </button>
</form>
{% endblock %}
