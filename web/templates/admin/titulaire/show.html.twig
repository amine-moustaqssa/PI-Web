{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ titulaire.prenom }} {{ titulaire.nom }}{% endblock %}

{% block body %}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <a href="{{ path('admin_titulaire_index') }}" class="text-decoration-none text-gray-400 mr-2">
            <i class="fas fa-arrow-left fa-sm"></i>
        </a>
        Fiche Client
    </h1>
    <a href="{{ path('admin_titulaire_edit', {id: titulaire.id}) }}" class="btn btn-sm btn-warning shadow-sm">
        <i class="fas fa-pen fa-sm mr-1"></i> Modifier
    </a>
</div>

<div class="row">
    <div class="col-lg-4">
        <div class="card shadow mb-4">
            <div class="card-body text-center py-5">
                <div class="rounded-circle bg-warning text-white d-inline-flex align-items-center justify-content-center mb-3"
                     style="width: 80px; height: 80px; font-size: 1.6rem;">
                    {{ titulaire.prenom|first|upper }}{{ titulaire.nom|first|upper }}
                </div>
                <h5 class="font-weight-bold text-gray-800 mb-1">{{ titulaire.prenom }} {{ titulaire.nom }}</h5>
                <p class="text-muted small mb-3">{{ titulaire.email }}</p>
                {% if titulaire.isVerified %}
                    <span class="badge badge-success px-3 py-2"><i class="fas fa-check mr-1"></i>Compte vérifié</span>
                {% else %}
                    <span class="badge badge-secondary px-3 py-2"><i class="fas fa-times mr-1"></i>Non vérifié</span>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-id-card mr-1"></i> Informations détaillées</h6>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-sm-4 font-weight-bold text-gray-600">Nom complet</div>
                    <div class="col-sm-8">{{ titulaire.prenom }} {{ titulaire.nom }}</div>
                </div>
                <hr>
                <div class="row mb-3">
                    <div class="col-sm-4 font-weight-bold text-gray-600">E-mail</div>
                    <div class="col-sm-8">{{ titulaire.email }}</div>
                </div>
                <hr>
                <div class="row mb-3">
                    <div class="col-sm-4 font-weight-bold text-gray-600">Adresse</div>
                    <div class="col-sm-8">
                        {{ titulaire.adresse|default('Non renseignée') }}
                        {% if titulaire.codePostal %} — {{ titulaire.codePostal }}{% endif %}
                    </div>
                </div>
                <hr>
                <div class="row mb-3">
                    <div class="col-sm-4 font-weight-bold text-gray-600">Compte vérifié</div>
                    <div class="col-sm-8">
                        {% if titulaire.isVerified %}
                            <span class="text-success font-weight-bold"><i class="fas fa-check-circle mr-1"></i>Oui</span>
                        {% else %}
                            <span class="text-muted"><i class="fas fa-times-circle mr-1"></i>Non</span>
                        {% endif %}
                    </div>
                </div>
                <hr>
                <div class="row">
                    <div class="col-sm-4 font-weight-bold text-gray-600">Rôles</div>
                    <div class="col-sm-8">
                        {% for role in titulaire.roles %}
                            <span class="badge badge-primary mr-1">{{ role }}</span>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        {# Profils Médicaux #}
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-info"><i class="fas fa-notes-medical mr-1"></i> Profils médicaux ({{ titulaire.profilsMedicaux|length }})</h6>
            </div>
            <div class="card-body">
                {% if titulaire.profilsMedicaux|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm">
                            <thead class="bg-light">
                                <tr>
                                    <th>#</th>
                                    <th>Nom</th>
                                    <th>Prénom</th>
                                    <th>Date de naissance</th>
                                    <th>Contact d'urgence</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for profil in titulaire.profilsMedicaux %}
                                <tr>
                                    <td class="text-muted small">{{ profil.id }}</td>
                                    <td>{{ profil.nom }}</td>
                                    <td>{{ profil.prenom }}</td>
                                    <td>{{ profil.dateNaissance ? profil.dateNaissance|date('d/m/Y') : '—' }}</td>
                                    <td>{{ profil.contactUrgence|default('—') }}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <p class="text-muted text-center mb-0"><i class="fas fa-info-circle mr-1"></i>Aucun profil médical enregistré.</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{% endblock %}
