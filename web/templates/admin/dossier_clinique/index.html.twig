{% extends 'admin/base_admin.html.twig' %}

{% block title %}Dossiers Cliniques{% endblock %}

{% block body %}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Dossiers Cliniques</h1>
    <a href="{{ path('admin_dossier_clinique_new') }}" class="btn btn-sm btn-success shadow-sm">
        <i class="fas fa-plus fa-sm text-white-50"></i>
        Ajouter un dossier clinique
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Liste des profils médicaux</h6>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for profil in profils %}
                    <tr>
                        <td>{{ profil.id }}</td>
                        <td>{{ profil.nom }}</td>
                        <td>{{ profil.prenom }}</td>
                        <td>

                            <!-- Voir -->
                            <a href="{{ path('admin_dossier_clinique_show', {id: profil.id}) }}"
                               class="btn btn-sm btn-info">
                                <i class="fas fa-eye"></i> Voir dossier
                            </a>

                            <!-- Modifier -->
                            <button class="btn btn-sm btn-primary"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editModal{{ profil.id }}">
                                <i class="fas fa-edit"></i> Modifier dossier
                            </button>

                            <!-- Voir rapports -->
                            <a href="{{ path('admin_dossier_clinique_reports', {id: profil.id}) }}"
                               class="btn btn-sm btn-warning">
                                <i class="fas fa-folder-open"></i> Voir rapports
                            </a>

                            <!-- Supprimer -->
                            <button type="button"
                                    class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteModal{{ profil.id }}">
                                <i class="fas fa-trash"></i> Supprimer
                            </button>

                            <!-- MODAL Modifier -->
                            <div class="modal fade" id="editModal{{ profil.id }}" tabindex="-1">
                                <div class="modal-dialog modal-lg">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">
                                                Modifier le dossier de {{ profil.nom }} {{ profil.prenom }}
                                            </h5>
                                            <button class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            {{ form_start(forms[profil.id]) }}
                                                {{ form_widget(forms[profil.id]) }}
                                                <button class="btn btn-primary mt-3">Enregistrer</button>
                                            {{ form_end(forms[profil.id]) }}
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- MODAL Supprimer -->
                            <div class="modal fade" id="deleteModal{{ profil.id }}" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Confirmer la suppression</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            Voulez-vous vraiment supprimer le dossier clinique de
                                            <strong>{{ profil.nom }} {{ profil.prenom }}</strong> ?
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary"
                                                    data-bs-dismiss="modal">Annuler</button>

                                            <form method="post"
                                                  action="{{ path('admin_dossier_clinique_delete', {id: profil.id}) }}">
                                                <input type="hidden" name="_token"
                                                       value="{{ csrf_token('delete' ~ profil.id) }}">
                                                <button type="submit" class="btn btn-danger">Supprimer</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center text-muted">
                            Aucun profil médical trouvé
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
