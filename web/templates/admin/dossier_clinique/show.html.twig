{# templates/admin/dossier_clinique/show.html.twig #}
{% extends 'admin/base_admin.html.twig' %}

{% block title %}Detail Dossier Clinique - CLINIQUE 360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ flasher_render() }}
{% endblock %}

{% block body %}
<div class="d-sm-flex align-items-center mb-4">
    <a href="{{ path('admin_dossier_clinique_index') }}" class="btn btn-sm btn-light shadow-sm mr-3">
        <i class="fas fa-arrow-left"></i> 
    </a>
    <h1 class="h3 mb-0 text-gray-800">Detail dossier Clinique</h1>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card shadow mb-4">
            <div class="card-header">
                <h6 class="m-0 font-weight-bold text-primary">Profil Médical</h6>
            </div>
            <div class="card-body">
                <p><strong>Nom :</strong> {{ profilMedical.nom }}</p>
                <p><strong>Prénom :</strong> {{ profilMedical.prenom }}</p>
                <p><strong>Date de naissance :</strong> {{ profilMedical.dateNaissance ? profilMedical.dateNaissance|date('d/m/Y') : 'Non renseignée' }}</p>
                <p><strong>Contact d'urgence :</strong> {{ profilMedical.contactUrgence }}</p>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow mb-4">
            <div class="card-header">
                <h6 class="m-0 font-weight-bold text-gray-800">Dossier Clinique</h6>
            </div>
            <div class="card-body">
                {% if profilMedical.dossierClinique %}
                    <p><strong>Antécédents :</strong> {{ profilMedical.dossierClinique.antecedents ?: 'Non renseigné' }}</p>
                    <p><strong>Allergies :</strong>
                        {% if profilMedical.dossierClinique.allergies %}
                            {{ profilMedical.dossierClinique.allergies|join(', ') }}
                        {% else %}
                            Aucune
                        {% endif %}
                    </p>
                    <p><strong>Nombre de rapports :</strong> {{ profilMedical.dossierClinique.rapportsMedicaux|length }}</p>
                    <a href="{{ path('admin_dossier_clinique_reports', {'id': profilMedical.dossierClinique.id}) }}" class="btn btn-primary mt-2">
                        Voir les rapports
                    </a>
                {% else %}
                    <p>Ce profil n'a pas encore de dossier clinique.</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ flasher_render() }}
{% endblock %}