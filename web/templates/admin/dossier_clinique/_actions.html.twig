{# templates/admin/dossier_clinique/_actions.html.twig #}
<a href="{{ path('admin_dossier_clinique_show', {id: profil.id}) }}" class="btn btn-sm btn-info">
    <i class="fas fa-eye"></i> Voir
</a>

{% if dossier %}
    <button class="btn btn-sm btn-primary edit-btn" data-id="{{ profil.id }}">
        <i class="fas fa-edit"></i> Modifier
    </button>

    <a href="{{ path('admin_dossier_clinique_reports', {id: profil.id}) }}" class="btn btn-sm btn-warning">
        <i class="fas fa-folder-open"></i> Rapports
    </a>

    <form method="post"
          action="{{ path('admin_dossier_clinique_delete', {id: profil.id}) }}"
          style="display:inline-block"
          onsubmit="return confirm('Confirmer la suppression ?')">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ profil.id) }}">
        <button class="btn btn-sm btn-danger">
            <i class="fas fa-trash"></i>
        </button>
    </form>
{% else %}
    <button class="btn btn-sm btn-secondary" disabled>
        <i class="fas fa-edit"></i>
    </button>
{% endif %}
