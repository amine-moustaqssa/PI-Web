{% if dossier %}
    <!-- Voir button -->
    <a href="{{ path('admin_dossier_clinique_show', {id: profil.id}) }}" class="btn btn-sm btn-info">
        <i class="fas fa-eye"></i> 
    </a>

    <!-- Modifier button -->
    <button class="btn btn-sm btn-primary edit-btn" data-id="{{ profil.id }}">
        <i class="fas fa-edit"></i> 
    </button>

    <!-- Supprimer button -->
    <form method="post"
          action="{{ path('admin_dossier_clinique_delete', {id: profil.id}) }}"
          style="display:inline-block"
          class="delete-form">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ profil.id) }}">
        <button type="button" class="btn btn-sm btn-secondary delete-btn">
            <i class="fas fa-trash"></i> 
        </button>
    </form>

    <!-- Rapports button -->
    <a href="{{ path('admin_dossier_clinique_reports', {id: profil.id}) }}" class="btn btn-sm btn-info">
        <i class="fas fa-folder-open"></i> 
    </a>
{% else %}
    <button class="btn btn-sm btn-secondary" disabled>
        <i class="fas fa-edit"></i>
    </button>
{% endif %}
