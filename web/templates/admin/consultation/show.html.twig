{% extends 'admin/base_admin.html.twig' %}

{% block title %}Détails Consultation{% endblock %}

{% block body %}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-stethoscope text-primary mr-2"></i> Consultation #{{ consultation.id }}
    </h1>
    <a href="{{ path('admin_consultation_index') }}" class="btn btn-secondary btn-sm">
        <i class="fas fa-arrow-left mr-1"></i> Retour à la liste
    </a>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-info-circle mr-1"></i> Informations</h6>
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr>
                        <th class="text-muted" width="40%">ID</th>
                        <td>{{ consultation.id }}</td>
                    </tr>
                    <tr>
                        <th class="text-muted">RDV</th>
                        <td>{{ consultation.rdvId ?? '—' }}</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Date effectuée</th>
                        <td>{{ consultation.dateEffectuee ? consultation.dateEffectuee|date('d/m/Y H:i') : '—' }}</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Statut</th>
                        <td>
                            {% if consultation.statut == 'terminé' %}
                                <span class="badge badge-success">Terminé</span>
                            {% elseif consultation.statut == 'en cours' %}
                                <span class="badge badge-warning text-dark">En cours</span>
                            {% elseif consultation.statut == 'planifié' %}
                                <span class="badge badge-info">Planifié</span>
                            {% else %}
                                <span class="badge badge-secondary">{{ consultation.statut }}</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th class="text-muted">Médecin</th>
                        <td>{{ consultation.medecin.id }}</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-notes-medical mr-1"></i> Notes privées</h6>
            </div>
            <div class="card-body">
                <p>{{ consultation.notesPrivees ?? 'Aucune note' }}</p>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('admin_consultation_edit', {'id': consultation.id}) }}" class="btn btn-warning btn-sm mr-2">
                <i class="fas fa-edit mr-1"></i> Modifier
            </a>
            <a href="{{ path('admin_constante_by_consultation', {'consultationId': consultation.id}) }}" class="btn btn-info btn-sm mr-2">
                <i class="fas fa-heartbeat mr-1"></i> Voir Constantes Vitales
            </a>
            <form method="post" action="{{ path('admin_consultation_delete', {'id': consultation.id}) }}" style="display:inline-block;" onsubmit="return confirm('Voulez-vous vraiment supprimer cette consultation ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ consultation.id) }}">
                <button class="btn btn-danger btn-sm">
                    <i class="fas fa-trash mr-1"></i> Supprimer
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
