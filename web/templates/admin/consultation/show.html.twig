{% extends 'base.html.twig' %}

{% block title %}Détails Consultation (Admin){% endblock %}

{% block body %}
<h1>Détails de la consultation</h1>

<table class="table">
    <tbody>
        <tr>
            <th>Id</th>
            <td>{{ consultation.id }}</td>
        </tr>
        <tr>
            <th>Rdv ID</th>
            <td>{{ consultation.rdvId }}</td>
        </tr>
        <tr>
            <th>Date effectuée</th>
            <td>{{ consultation.dateEffectuee ? consultation.dateEffectuee|date('Y-m-d H:i:s') : '' }}</td>
        </tr>
        <tr>
            <th>Statut</th>
            <td>{{ consultation.statut }}</td>
        </tr>
        <tr>
            <th>Notes privées</th>
            <td>{{ consultation.notesPrivees }}</td>
        </tr>
        <tr>
            <th>Médecin</th>
            <td>{{ consultation.medecin.id }}</td>
        </tr>
    </tbody>
</table>

<a href="{{ path('admin_consultation_edit', {'id': consultation.id}) }}">Modifier</a>

{{ include('admin/consultation/_delete_form.html.twig') }}

<a href="{{ path('admin_consultation_index') }}">Retour à la liste</a>
{% endblock %}
