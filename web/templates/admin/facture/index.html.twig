{% extends 'admin/base_admin.html.twig' %}

{% block title %}Mes Factures{% endblock %}

{% block body %}
    <h1>Mes Factures</h1>

    {# Search Form #}
    <div class="mb-4">
        <div class="row">
            <div class="col-md-6">
                <input type="text" 
                       id="search-input" 
                       class="form-control" 
                       placeholder="Rechercher par référence, montant ou statut...">
            </div>
            <div class="col-md-3">
                <select id="status-filter" class="form-control">
                    <option value="">Tous les statuts</option>
                    <option value="PAYEE">Payée</option>
                    <option value="EN_ATTENTE">En attente</option>
                    <option value="ANNULEE">Annulée</option>
                </select>
            </div>
            <div class="col-md-3">
                <button id="reset-search" class="btn btn-secondary">
                    <i class="fas fa-redo"></i> Réinitialiser
                </button>
            </div>
        </div>
    </div>

    {# Loading Indicator #}
    <div id="loading-indicator" class="text-center my-3" style="display: none;">
        <div class="spinner-border text-primary" role="status">
            <span class="sr-only">Chargement...</span>
        </div>
    </div>

    {# Exchange rate banner #}
    <div id="rate-banner" class="alert alert-info py-2 mb-3" style="display:none;">
        <i class="fas fa-exchange-alt mr-1"></i>
        Taux en temps réel : <strong>1 TND = <span id="live-rate">...</span> EUR</strong>
        <small class="text-muted ml-2">— Source: exchangerate-api.com</small>
        <span id="rate-loading" class="ml-2">
            <span class="spinner-border spinner-border-sm text-info"></span>
        </span>
    </div>

    {# Factures Table #}
    <div id="factures-table-container">
        <table class="table table-hover">
            <thead class="thead-light">
                <tr>
                    <th>ID</th>
                    <th>Référence</th>
                    <th>Montant (TND)</th>
                    <th>Équivalent <span class="badge badge-info ml-1">EUR</span></th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="factures-tbody">
                {% include 'admin/facture/_table_rows.html.twig' %}
            </tbody>
        </table>
    </div>

    <div class="mt-4 d-flex gap-2">
        <a href="{{ path('app_admin_facture_new') }}" class="btn btn-primary">
            <i class="fas fa-plus-circle"></i> Créer une nouvelle facture
        </a>
        <a href="{{ path('stats_dashboard') }}" class="btn btn-info text-white">
            <i class="fas fa-chart-line"></i> Tableau de Bord Statistiques
        </a>
        <a href="{{ path('pdf_all_factures') }}" class="btn btn-danger" target="_blank">
            <i class="fas fa-file-pdf"></i> Imprimer PDF
        </a>
    </div>

    {# ── Groq AI Floating Button ── #}
    <button id="ai-toggle-btn" title="Assistant IA Financier"
        style="
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #4e73df, #224abe);
            border: none;
            color: white;
            font-size: 24px;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(78,115,223,0.5);
            z-index: 9999;
            transition: transform 0.2s;
        "
        onmouseover="this.style.transform='scale(1.1)'"
        onmouseout="this.style.transform='scale(1)'">
        🤖
    </button>

    {# ── Groq AI Chat Window ── #}
    <div id="ai-chat-window" style="
            display: none;
            position: fixed;
            bottom: 100px;
            right: 30px;
            width: 370px;
            height: 500px;
            background: white;
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.18);
            z-index: 9998;
            flex-direction: column;
            overflow: hidden;
            font-family: sans-serif;
        ">

        {# Chat Header #}
        <div style="
                background: linear-gradient(135deg, #4e73df, #224abe);
                color: white;
                padding: 14px 18px;
                display: flex;
                align-items: center;
                justify-content: space-between;
            ">
            <div>
                <strong>🤖 Assistant IA Financier</strong>
                <div style="font-size:11px; opacity:0.85;">Propulsé par Groq AI</div>
            </div>
            <button id="ai-close-btn" style="
                    background:none; border:none; color:white;
                    font-size:20px; cursor:pointer; line-height:1;
                ">×</button>
        </div>

        {# Quick Questions #}
        <div style="padding: 10px 12px; background:#f8f9fc; border-bottom:1px solid #e3e6f0;">
            <div style="font-size:11px; color:#666; margin-bottom:6px;">Questions rapides :</div>
            <div style="display:flex; flex-wrap:wrap; gap:5px;">
                <button class="quick-btn" data-q="Résume la situation financière globale de la clinique">
                    📊 Situation globale
                </button>
                <button class="quick-btn" data-q="Quelles sont les factures en attente de paiement ?">
                    ⏳ Factures en attente
                </button>
                <button class="quick-btn" data-q="Analyse les revenus et donne des recommandations">
                    💡 Recommandations
                </button>
            </div>
        </div>

        {# Chat Messages #}
        <div id="ai-messages" style="
                flex: 1;
                overflow-y: auto;
                padding: 12px;
                display: flex;
                flex-direction: column;
                gap: 10px;
                height: 280px;
            ">
            {# Welcome message #}
            <div class="ai-msg-bot" style="
                    background: #f0f4ff;
                    border-radius: 12px 12px 12px 0;
                    padding: 10px 14px;
                    font-size: 13px;
                    color: #333;
                    max-width: 85%;
                ">
                👋 Bonjour ! Je suis votre assistant financier IA.<br>
                Je connais vos données de facturation en temps réel.<br>
                Posez-moi une question !
            </div>
        </div>

        {# Chat Input #}
        <div style="
                padding: 10px 12px;
                border-top: 1px solid #e3e6f0;
                display: flex;
                gap: 8px;
                background: white;
            ">
            <input type="text" id="ai-input"
                placeholder="Posez une question..."
                style="
                    flex:1;
                    border: 1px solid #d1d3e2;
                    border-radius: 20px;
                    padding: 8px 14px;
                    font-size: 13px;
                    outline: none;
                ">
            <button id="ai-send-btn" style="
                    background: linear-gradient(135deg, #4e73df, #224abe);
                    color: white;
                    border: none;
                    border-radius: 50%;
                    width: 38px;
                    height: 38px;
                    cursor: pointer;
                    font-size: 16px;
                ">➤</button>
        </div>
    </div>

    {# Pass facture data to JS as JSON for Groq context #}
    <script>
        const facturesData = [
            {% for facture in factures %}
            {
                id: {{ facture.id }},
                reference: "{{ facture.reference }}",
                montant: {{ facture.montantTotal }},
                statut: "{{ facture.statut }}"
            }{% if not loop.last %},{% endif %}
            {% endfor %}
        ];
    </script>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    document.addEventListener('DOMContentLoaded', function () {

const GROQ_API_KEY = '{{ groq_api_key }}';
const GROQ_URL = 'https://api.groq.com/openai/v1/chat/completions';
        // ── Currency API ──────────────────────────────────────────
        const rateBanner  = document.getElementById('rate-banner');
        const liveRate    = document.getElementById('live-rate');
        const rateLoading = document.getElementById('rate-loading');
        let eurRate = null;

        rateBanner.style.display = 'block';

        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 8000);

        fetch('https://api.exchangerate-api.com/v4/latest/TND', { signal: controller.signal })
            .then(r => { clearTimeout(timeoutId); return r.json(); })
            .then(data => {
                eurRate = data.rates['EUR'];
                liveRate.textContent = eurRate.toFixed(4);
                rateLoading.style.display = 'none';
                fillEurCells(eurRate);
            })
            .catch((err) => {
                clearTimeout(timeoutId);
                console.error('Currency API error:', err);
                liveRate.textContent = 'indisponible';
                rateLoading.style.display = 'none';
                document.querySelectorAll('.eur-cell').forEach(c => {
                    c.innerHTML = '<span class="text-muted small">N/A</span>';
                });
            });

        function fillEurCells(rate) {
            document.querySelectorAll('.eur-cell').forEach(cell => {
                const tnd      = parseFloat(cell.getAttribute('data-tnd'));
                const converted = (tnd * rate).toFixed(2);
                cell.innerHTML = `<span class="text-success font-weight-bold">${converted} €</span>`;
            });
        }

        // ── AJAX Search ───────────────────────────────────────────
        const searchInput      = document.getElementById('search-input');
        const statusFilter     = document.getElementById('status-filter');
        const resetButton      = document.getElementById('reset-search');
        const loadingIndicator = document.getElementById('loading-indicator');
        const facturesTbody    = document.getElementById('factures-tbody');
        let searchTimeout;

        function searchFactures() {
            loadingIndicator.style.display = 'block';
            fetch('{{ path('app_admin_facture_search') }}?' + new URLSearchParams({
                search: searchInput.value,
                status: statusFilter.value
            }), { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(r => { if (!r.ok) throw new Error('Erreur réseau'); return r.text(); })
            .then(html => {
                facturesTbody.innerHTML = html;
                loadingIndicator.style.display = 'none';
                if (eurRate) fillEurCells(eurRate);
            })
            .catch(err => {
                loadingIndicator.style.display = 'none';
                facturesTbody.innerHTML = `<tr><td colspan="6" class="text-center text-danger">Erreur: ${err.message}</td></tr>`;
            });
        }

        searchInput.addEventListener('input', () => {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(searchFactures, 300);
        });
        statusFilter.addEventListener('change', searchFactures);
        resetButton.addEventListener('click', () => {
            searchInput.value = '';
            statusFilter.value = '';
            searchFactures();
        });

        // ── Groq AI Chat ────────────────────────────────────────
        const toggleBtn   = document.getElementById('ai-toggle-btn');
        const chatWindow  = document.getElementById('ai-chat-window');
        const closeBtn    = document.getElementById('ai-close-btn');
        const messagesDiv = document.getElementById('ai-messages');
        const aiInput     = document.getElementById('ai-input');
        const sendBtn     = document.getElementById('ai-send-btn');

        // Toggle chat window
        toggleBtn.addEventListener('click', () => {
            const isVisible = chatWindow.style.display === 'flex';
            chatWindow.style.display = isVisible ? 'none' : 'flex';
            chatWindow.style.flexDirection = 'column';
            if (!isVisible) aiInput.focus();
        });

        closeBtn.addEventListener('click', () => {
            chatWindow.style.display = 'none';
        });

        // Quick question buttons
        document.querySelectorAll('.quick-btn').forEach(btn => {
            btn.style.cssText = `
                background: white;
                border: 1px solid #4e73df;
                color: #4e73df;
                border-radius: 12px;
                padding: 4px 10px;
                font-size: 11px;
                cursor: pointer;
            `;
            btn.addEventListener('click', () => {
                askGroq(btn.getAttribute('data-q'));
            });
        });

        // Send on Enter
        aiInput.addEventListener('keydown', e => {
            if (e.key === 'Enter' && aiInput.value.trim()) {
                askGroq(aiInput.value.trim());
                aiInput.value = '';
            }
        });

        sendBtn.addEventListener('click', () => {
            if (aiInput.value.trim()) {
                askGroq(aiInput.value.trim());
                aiInput.value = '';
            }
        });

        // Build context from real facture data
        function buildContext() {
            const total      = facturesData.length;
            const payees     = facturesData.filter(f => f.statut === 'PAYEE').length;
            const attente    = facturesData.filter(f => f.statut === 'EN_ATTENTE').length;
            const annulees   = facturesData.filter(f => f.statut === 'ANNULEE').length;
            const totalMontant = facturesData.reduce((s, f) => s + f.montant, 0).toFixed(2);
            const montantPayees = facturesData.filter(f => f.statut === 'PAYEE')
                                              .reduce((s, f) => s + f.montant, 0).toFixed(2);
            const montantAttente = facturesData.filter(f => f.statut === 'EN_ATTENTE')
                                               .reduce((s, f) => s + f.montant, 0).toFixed(2);

            return `Tu es un assistant financier expert pour une clinique médicale en Tunisie.
Tu dois répondre UNIQUEMENT en français, de manière concise et professionnelle.
Tu as accès aux données financières réelles suivantes :

📊 DONNÉES ACTUELLES DE LA CLINIQUE :
- Total factures : ${total}
- Factures payées : ${payees} (${montantPayees} TND encaissés)
- Factures en attente : ${attente} (${montantAttente} TND à récupérer)
- Factures annulées : ${annulees}
- Montant total facturé : ${totalMontant} TND

📋 LISTE DES FACTURES :
${facturesData.map(f => `  - Réf: ${f.reference} | ${f.montant} TND | Statut: ${f.statut}`).join('\n')}

Réponds de façon courte (3-5 lignes max), précise et utile. Utilise les vrais chiffres ci-dessus.`;
        }

        function addMessage(text, isUser) {
            const div = document.createElement('div');
            div.style.cssText = isUser
                ? 'background:#4e73df; color:white; border-radius:12px 12px 0 12px; padding:10px 14px; font-size:13px; max-width:85%; align-self:flex-end;'
                : 'background:#f0f4ff; color:#333; border-radius:12px 12px 12px 0; padding:10px 14px; font-size:13px; max-width:85%;';
            div.textContent = text;
            messagesDiv.appendChild(div);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }

        function addTypingIndicator() {
            const div = document.createElement('div');
            div.id = 'typing-indicator';
            div.style.cssText = 'background:#f0f4ff; border-radius:12px 12px 12px 0; padding:10px 14px; font-size:13px; max-width:85%; color:#666;';
            div.innerHTML = '⏳ Analyse en cours...';
            messagesDiv.appendChild(div);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }

        function removeTypingIndicator() {
            const el = document.getElementById('typing-indicator');
            if (el) el.remove();
        }

        function askGroq(question) {
            addMessage(question, true);
            addTypingIndicator();
            sendBtn.disabled = true;

            const prompt = buildContext() + `\n\nQuestion de l'administrateur : ${question}`;

            fetch(GROQ_URL, {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${GROQ_API_KEY}`
    },
    body: JSON.stringify({
        model: 'llama-3.1-8b-instant',
        messages: [
            { role: 'user', content: prompt }
        ],
        max_tokens: 500
    })
})
.then(r => r.json())
.then(data => {
    removeTypingIndicator();
    const reply = data?.choices?.[0]?.message?.content
        || "Je n'ai pas pu générer une réponse.";
    addMessage(reply, false);
})
.catch(() => {
    removeTypingIndicator();
    addMessage("❌ Erreur de connexion à Groq.", false);
})
.finally(() => {
    sendBtn.disabled = false;
});
        }
    });
    </script>
{% endblock %}