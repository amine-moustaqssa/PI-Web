{% extends 'admin/base_admin.html.twig' %}

{% block title %}Mes Factures{% endblock %}

{% block body %}
    <h1>Mes Factures</h1>

    {# Search Form #}
    <div class="mb-4">
        <div class="row">
            <div class="col-md-6">
                <input type="text" 
                       id="search-input" 
                       class="form-control" 
                       placeholder="Rechercher par référence, montant ou statut...">
            </div>
            <div class="col-md-3">
                <select id="status-filter" class="form-control">
                    <option value="">Tous les statuts</option>
                    <option value="PAYEE">Payée</option>
                    <option value="EN_ATTENTE">En attente</option>
                    <option value="ANNULEE">Annulée</option>
                </select>
            </div>
            <div class="col-md-3">
                <button id="reset-search" class="btn btn-secondary">
                    <i class="fas fa-redo"></i> Réinitialiser
                </button>
            </div>
        </div>
    </div>

    {# Loading Indicator #}
    <div id="loading-indicator" class="text-center my-3" style="display: none;">
        <div class="spinner-border text-primary" role="status">
            <span class="sr-only">Chargement...</span>
        </div>
    </div>

    {# Factures Table #}
    <div id="factures-table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Référence</th>
                    <th>Montant</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="factures-tbody">
                {% include 'admin/facture/_table_rows.html.twig' %}
            </tbody>
        </table>
    </div>

    <div class="mt-4">
        <a href="{{ path('app_admin_facture_new') }}" class="btn btn-primary">
            <i class="fas fa-plus-circle"></i> Créer une nouvelle facture
        </a>
    </div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('search-input');
            const statusFilter = document.getElementById('status-filter');
            const resetButton = document.getElementById('reset-search');
            const loadingIndicator = document.getElementById('loading-indicator');
            const facturesTbody = document.getElementById('factures-tbody');
            
            let searchTimeout;

            // Function to perform AJAX search
            function searchFactures() {
                const searchTerm = searchInput.value;
                const status = statusFilter.value;

                // Show loading indicator
                loadingIndicator.style.display = 'block';

                // Make AJAX request
                fetch('{{ path('app_admin_facture_search') }}?' + new URLSearchParams({
                    search: searchTerm,
                    status: status
                }), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Erreur réseau: ' + response.status);
                    }
                    return response.text();
                })
                .then(html => {
                    facturesTbody.innerHTML = html;
                    loadingIndicator.style.display = 'none';
                })
                .catch(error => {
                    console.error('Erreur détaillée:', error);
                    loadingIndicator.style.display = 'none';
                    facturesTbody.innerHTML = '<tr><td colspan="5" class="text-center text-danger">Une erreur est survenue: ' + error.message + '</td></tr>';
                    
                    // Show alert for debugging
                    alert('Erreur AJAX: ' + error.message);
                });
            }

            // Search input with debounce
            searchInput.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(searchFactures, 300);
            });

            // Status filter with error handling
            statusFilter.addEventListener('change', function() {
                try {
                    searchFactures();
                } catch (error) {
                    console.error('Erreur lors du changement de statut:', error);
                    alert('Erreur: ' + error.message);
                }
            });

            // Reset button
            resetButton.addEventListener('click', function() {
                searchInput.value = '';
                statusFilter.value = '';
                searchFactures();
            });
        });
    </script>
{% endblock %}