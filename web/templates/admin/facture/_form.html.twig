{{ form_start(form, {
    'attr': { 'novalidate': 'novalidate' }
}) }}

    {# Reference #}
    <div class="form-group">
        <label class="font-weight-bold text-gray-700">
            <i class="fas fa-hashtag text-primary mr-1"></i>
            Référence
        </label>
        {{ form_widget(form.reference) }}
        {% if form.reference.vars.errors|length > 0 %}
            <div class="text-danger small mt-1">{{ form_errors(form.reference) }}</div>
        {% endif %}
    </div>

    {# Montant #}
    <div class="form-group">
        <label class="font-weight-bold text-gray-700">
            <i class="fas fa-money-bill-wave text-success mr-1"></i>
            Montant Total (TND)
        </label>
        <div class="input-group">
            <div class="input-group-prepend">
                <span class="input-group-text bg-success text-white font-weight-bold">TND</span>
            </div>
            {{ form_widget(form.montantTotal) }}
        </div>
        {% if form.montantTotal.vars.errors|length > 0 %}
            <div class="text-danger small mt-1">{{ form_errors(form.montantTotal) }}</div>
        {% endif %}
    </div>

    {# Statut #}
    <div class="form-group">
        <label class="font-weight-bold text-gray-700">
            <i class="fas fa-tag text-warning mr-1"></i>
            Statut
        </label>
        {{ form_widget(form.statut) }}
        {% if form.statut.vars.errors|length > 0 %}
            <div class="text-danger small mt-1">{{ form_errors(form.statut) }}</div>
        {% endif %}
    </div>

    {# Consultation #}
    <div class="form-group">
        <label class="font-weight-bold text-gray-700">
            <i class="fas fa-stethoscope text-info mr-1"></i>
            Consultation associée
        </label>
        {{ form_widget(form.consultation) }}
        {% if form.consultation.vars.errors|length > 0 %}
            <div class="text-danger small mt-1">{{ form_errors(form.consultation) }}</div>
        {% endif %}
    </div>

    {# Titulaire #}
    <div class="form-group">
        <label class="font-weight-bold text-gray-700">
            <i class="fas fa-user text-primary mr-1"></i>
            Titulaire
        </label>
        {{ form_widget(form.titulaire) }}
        {% if form.titulaire.vars.errors|length > 0 %}
            <div class="text-danger small mt-1">{{ form_errors(form.titulaire) }}</div>
        {% endif %}
    </div>

    <hr>

    {# Buttons #}
    <div class="d-flex justify-content-between align-items-center">
        <a href="{{ path('app_admin_facture_index') }}" class="btn btn-secondary">
            <i class="fas fa-times mr-1"></i> Annuler
        </a>
        <button type="submit" class="btn btn-primary px-4">
            <i class="fas fa-save mr-1"></i> Enregistrer la Facture
        </button>
    </div>

{{ form_end(form) }}