<section class="py-5 bg-light" id="contact">
    <div class="container px-5 my-5">
        <div class="row gx-5 justify-content-center">
            <div class="col-lg-10">
                <div class="text-center mb-5">
                    <h2 class="fw-bold">Contactez-nous</h2>
                    <p class="text-muted">Une question ? Besoin d'aide ? Notre équipe est là pour vous.</p>
                </div>
            </div>
        </div>

        <div class="row gx-5">
            <div class="col-lg-5 mb-5 mb-lg-0">
                <div class="d-flex flex-column h-100">
                    <div class="mb-4">
                        <div class="feature-icon-box bg-primary bg-opacity-10 text-primary mb-3">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>
                        <h3 class="h5 fw-bold">Notre Adresse</h3>
                        <p class="text-muted">123 Avenue de la Santé<br>Tunis, Tunisie 1000</p>
                    </div>
                    
                    <div class="mb-4">
                        <div class="feature-icon-box bg-primary bg-opacity-10 text-primary mb-3">
                            <i class="bi bi-telephone-fill"></i>
                        </div>
                        <h3 class="h5 fw-bold">Téléphone</h3>
                        <p class="text-muted">+216 71 000 000</p>
                    </div>

                    <div class="mb-4">
                        <div class="feature-icon-box bg-primary bg-opacity-10 text-primary mb-3">
                            <i class="bi bi-envelope-fill"></i>
                        </div>
                        <h3 class="h5 fw-bold">Email</h3>
                        <p class="text-muted">contact@maclinique.tn</p>
                    </div>
                    
                    <div class="mt-auto">
                        <p class="small text-muted">Urgences 24/7 disponibles via notre numéro principal.</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="contact-card p-5">
                    <form>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <input type="text" class="form-control form-control-lg" placeholder="Votre Nom">
                            </div>
                            <div class="col-md-6 mb-3">
                                <input type="email" class="form-control form-control-lg" placeholder="Votre Email">
                            </div>
                        </div>
                        <div class="mb-3">
                            <input type="text" class="form-control form-control-lg" placeholder="Sujet">
                        </div>
                        <div class="mb-3">
                            <textarea class="form-control form-control-lg" rows="5" placeholder="Votre Message"></textarea>
                        </div>
                        <div class="d-grid">
                            <button class="btn btn-primary btn-lg rounded-pill" type="submit">Envoyer le message</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>