{% extends 'front/base_front.html.twig' %}

{% block title %}Vérification en deux étapes{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container px-5">
        <div class="row justify-content-center">
            <div class="col-lg-5">
                <div class="card border-0 shadow rounded-3 overflow-hidden">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h2 class="fw-bolder">Vérification en deux étapes</h2>
                            <p class="lead fw-normal text-muted mb-0">Entrez le code généré par votre application d'authentification</p>
                        </div>

                        {% if authenticationError is defined and authenticationError %}
                            <div class="alert alert-danger">
                                {{ authenticationError|trans(authenticationErrorData, 'security') }}
                            </div>
                        {% endif %}

                        <form method="post" action="{{ checkPathRoute ? path(checkPathRoute) : checkPathUrl }}">
                            {% if isCsrfProtectionEnabled %}
                                <input type="hidden" name="{{ csrfParameterName }}" value="{{ csrf_token(csrfTokenId) }}">
                            {% endif %}

                            <div class="form-floating mb-3">
                                <input
                                    type="text"
                                    id="authCode"
                                    name="{{ authCodeParameterName }}"
                                    class="form-control"
                                    placeholder="000000"
                                    maxlength="6"
                                    inputmode="numeric"
                                    autocomplete="one-time-code"
                                    autofocus
                                    required
                                    style="letter-spacing: .3em; font-size: 1.2rem; text-align: center;"
                                >
                                <label for="authCode">Code à 6 chiffres</label>
                            </div>

                            <div class="d-grid">
                                <button class="btn btn-primary btn-lg" type="submit">Vérifier</button>
                            </div>

                            <div class="text-center mt-3">
                                <a href="{{ logoutPath }}" class="small text-muted">Annuler et revenir à la connexion</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
