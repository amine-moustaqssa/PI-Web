<div class="modal fade" id="addProfilModal" tabindex="-1" role="dialog" aria-labelledby="addProfilModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content modal-content-modern">
            
            <div class="modal-header modal-header-modern">
                <div>
                    <h5 class="modal-title modal-title-modern" id="addProfilModalLabel">Créer un Nouveau Profil</h5>
                    <p class="modal-subtitle">Ajoutez un membre de votre famille.</p>
                </div>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                {% if form is defined %}
                    {{ form_start(form) }}
                        
                        {{ form_errors(form) }}

                        <div class="form-group form-group-modern">
                            <label class="form-label-modern">Prénom <span class="required-star">*</span></label>
                            {{ form_widget(form.prenom, {'attr': {'class': 'form-control form-control-modern', 'placeholder': 'ex: Ahmed'}}) }}
                            {{ form_errors(form.prenom) }}
                        </div>

                        <div class="form-group form-group-modern">
                            <label class="form-label-modern">Nom <span class="required-star">*</span></label>
                            {{ form_widget(form.nom, {'attr': {'class': 'form-control form-control-modern', 'placeholder': 'ex: Ben Salah'}}) }}
                            {{ form_errors(form.nom) }}
                        </div>

                        <div class="form-group form-group-modern">
                            <label class="form-label-modern">Date de Naissance <span class="required-star">*</span></label>
                            {# Safe Check for snake_case/camelCase #}
                            {% if form.dateNaissance is defined %}
                                {{ form_widget(form.dateNaissance, {'attr': {'class': 'form-control form-control-modern'}}) }}
                                {{ form_errors(form.dateNaissance) }}
                            {% elseif form.date_naissance is defined %}
                                {{ form_widget(form.date_naissance, {'attr': {'class': 'form-control form-control-modern'}}) }}
                                {{ form_errors(form.date_naissance) }}
                            {% endif %}
                        </div>

                        <div class="form-group form-group-modern">
                            <label class="form-label-modern">Contact Urgence</label>
                            {# Safe Check for snake_case/camelCase #}
                            {% if form.contactUrgence is defined %}
                                {{ form_widget(form.contactUrgence, {'attr': {'class': 'form-control form-control-modern', 'placeholder': 'ex: 98 123 456'}}) }}
                                {{ form_errors(form.contactUrgence) }}
                            {% elseif form.contact_urgence is defined %}
                                {{ form_widget(form.contact_urgence, {'attr': {'class': 'form-control form-control-modern', 'placeholder': 'ex: 98 123 456'}}) }}
                                {{ form_errors(form.contact_urgence) }}
                            {% endif %}
                        </div>
                        
                        {{ form_rest(form) }}

                        <div class="modal-footer border-top-0 px-0 pb-0 pt-3">
                            <button type="button" class="btn btn-ghost-modern" data-dismiss="modal">Annuler</button>
                            <button type="submit" class="btn btn-primary-modern">Créer le Profil</button>
                        </div>

                    {{ form_end(form) }}
                {% else %}
                    <div class="alert alert-danger">
                        Erreur : Formulaire introuvable.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>