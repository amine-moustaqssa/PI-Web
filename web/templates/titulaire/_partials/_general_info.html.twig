<div class="row">
    <div class="col-xl-12 col-md-12 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Informations Générales</div>
                        <div class="row">
                            <div class="col-md-4">
                                <strong>Date de Naissance :</strong> 
                                {{ activeProfil.dateNaissance|date('d M Y') }} 
                                ({{ date('now').diff(activeProfil.dateNaissance).y }} ans)
                            </div>
                            <div class="col-md-4">
                                <strong>Contact Urgence :</strong> 
                                {{ activeProfil.contactUrgence }}
                            </div>
                            <div class="col-md-4">
                                <strong>Statut :</strong> Validé
                            </div>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-id-card fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>