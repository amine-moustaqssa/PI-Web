{% extends 'base.html.twig' %}

{% block sidebar %}
    {% include 'titulaire/_partials/_sidebar.html.twig' %}
{% endblock %}

{% block title %}Mes Paiements{% endblock %}

{% block body %}
<div class="container-fluid">

    {# Page Heading #}
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-credit-card mr-2"></i>Mes Paiements</h1>
        <a href="{{ path('app_patient_paiement_new') }}" class="d-none d-sm-inline-block btn btn-sm btn-success shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50 mr-1"></i> Nouveau paiement
        </a>
    </div>

    {# Stats Cards #}
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total paiements</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">{{ paiements|length }}</div>
                    </div>
                    <i class="fas fa-receipt fa-2x text-gray-300"></i>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Montant total</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            {% set total = 0 %}
                            {% for p in paiements %}{% set total = total + p.montant %}{% endfor %}
                            {{ total }} DT
                        </div>
                    </div>
                    <i class="fas fa-coins fa-2x text-gray-300"></i>
                </div>
            </div>
        </div>
    </div>

    {# Table Card #}
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Historique des paiements</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle" id="paiementTable" width="100%" cellspacing="0">
                    <thead class="bg-light">
                        <tr>
                            <th style="width: 5%;">#</th>
                            <th>Date</th>
                            <th class="text-center">Montant</th>
                            <th class="text-center" style="width: 12%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for paiement in paiements %}
                        <tr>
                            <td class="text-muted small">{{ paiement.id }}</td>
                            <td>
                                <i class="fas fa-calendar-day text-gray-400 mr-1"></i>
                                {{ paiement.datePaiement ? paiement.datePaiement|date('d/m/Y à H:i') : '—' }}
                            </td>
                            <td class="text-center">
                                <span class="font-weight-bold text-success">{{ paiement.montant }} DT</span>
                            </td>
                            <td class="text-center">
                                <a href="{{ path('app_patient_paiement_show', {'id': paiement.id}) }}" class="btn btn-info btn-circle btn-sm" title="Voir détails">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <i class="fas fa-receipt fa-3x text-gray-300 mb-3 d-block"></i>
                                <h6 class="text-gray-500">Aucun paiement trouvé</h6>
                                <a href="{{ path('app_patient_paiement_new') }}" class="btn btn-success btn-sm mt-2">
                                    <i class="fas fa-plus mr-1"></i> Effectuer un paiement
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function() {
            $('#paiementTable').DataTable({
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json"
                },
                pageLength: 10,
                order: [[1, 'desc']]
            });
        });
    </script>
{% endblock %}