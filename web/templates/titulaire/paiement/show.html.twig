{% extends 'base.html.twig' %}

{% block sidebar %}
    {% include 'titulaire/_partials/_sidebar.html.twig' %}
{% endblock %}

{% block title %}Détails du Paiement #{{ paiement.id }}{% endblock %}

{% block body %}
<div class="container-fluid">

    {# Page Heading #}
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-credit-card mr-2"></i>Détails du Paiement</h1>
        <a href="{{ path('app_patient_paiement_index') }}" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm">
            <i class="fas fa-arrow-left fa-sm text-white-50 mr-1"></i> Retour à la liste
        </a>
    </div>

    <div class="row">
        {# Main Info Card #}
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex align-items-center">
                    <i class="fas fa-info-circle text-primary mr-2"></i>
                    <h6 class="m-0 font-weight-bold text-primary">Informations du paiement</h6>
                </div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted font-weight-bold" style="width: 35%;">
                                    <i class="fas fa-hashtag mr-2 text-gray-400"></i>Référence
                                </td>
                                <td>
                                    <span class="badge badge-light border px-3 py-2" style="font-size:.9rem;">#{{ paiement.id }}</span>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted font-weight-bold">
                                    <i class="fas fa-calendar-day mr-2 text-gray-400"></i>Date du paiement
                                </td>
                                <td>{{ paiement.datePaiement ? paiement.datePaiement|date('d/m/Y à H:i') : '—' }}</td>
                            </tr>
                            <tr>
                                <td class="text-muted font-weight-bold">
                                    <i class="fas fa-coins mr-2 text-gray-400"></i>Montant
                                </td>
                                <td>
                                    <span class="h5 font-weight-bold text-success mb-0">{{ paiement.montant }} DT</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        {# Sidebar Actions #}
        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-bolt mr-2"></i>Actions</h6>
                </div>
                <div class="card-body text-center">
                    <a href="{{ path('app_patient_paiement_index') }}" class="btn btn-outline-primary btn-block mb-2">
                        <i class="fas fa-list mr-1"></i> Tous les paiements
                    </a>
                    <a href="{{ path('app_patient_paiement_new') }}" class="btn btn-success btn-block">
                        <i class="fas fa-plus mr-1"></i> Nouveau paiement
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}