{% extends 'base.html.twig' %}

{% block title %}Médicaments - Pharmacie{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .search-box {
            position: relative;
            max-width: 420px;
        }
        .search-box .form-control {
            border-radius: 8px;
            border: 1px solid #e3e8ee;
            padding: 10px 14px 10px 42px;
            font-size: 0.9rem;
            transition: all 0.2s;
        }
        .search-box .form-control:focus {
            border-color: #4e73df;
            box-shadow: 0 0 0 3px rgba(78, 115, 223, 0.15);
        }
        .search-box .search-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #b7bac6;
            font-size: 0.9rem;
        }
        .stock-badge {
            font-size: 0.78rem;
            padding: 4px 10px;
            border-radius: 20px;
            font-weight: 600;
        }
        .stock-high { background: #e8f5e9; color: #2e7d32; }
        .stock-medium { background: #fff8e1; color: #f57f17; }
        .stock-low { background: #fce4ec; color: #c62828; }
        .pharmacy-badge {
            font-size: 0.78rem;
            padding: 4px 10px;
            border-radius: 20px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }
        .pharmacy-a { background: #e3f2fd; color: #1565c0; }
        .pharmacy-b { background: #f3e5f5; color: #7b1fa2; }
        .price-tag {
            font-weight: 700;
            color: #1a1f36;
            font-size: 1rem;
        }
        .sku-tag {
            font-family: 'Courier New', monospace;
            font-size: 0.8rem;
            color: #697386;
            background: #f7f9fc;
            padding: 2px 8px;
            border-radius: 4px;
        }
        .med-table th {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #858796;
            border-top: none;
            border-bottom: 2px solid #e3e6f0;
            padding: 12px 16px;
        }
        .med-table td {
            padding: 14px 16px;
            vertical-align: middle;
            border-top: 1px solid #f0f2f5;
        }
        .med-table tbody tr:hover {
            background-color: #f8f9ff;
        }
        .med-name {
            font-weight: 600;
            color: #1a1f36;
        }
        .empty-state-icon {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: #f0f2f5;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
        }
    </style>
{% endblock %}

{% block sidebar %}
    {% include 'titulaire/_partials/_sidebar.html.twig' %}
{% endblock %}

{% block topbar %}{% endblock %}

{% block body %}
    <div class="mt-4">

        {# --- HEADER --- #}
        <div class="d-sm-flex align-items-center justify-content-between mb-4">
            <div class="d-flex align-items-center">
                <div class="bg-gradient-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm mr-3" style="width: 48px; height: 48px;">
                    <i class="fas fa-pills fa-lg"></i>
                </div>
                <div>
                    <h1 class="h3 mb-0 text-gray-800 font-weight-bold">Médicaments</h1>
                    <span class="text-muted small">Inventaire Pharmacie Partenaire</span>
                </div>
            </div>
        </div>

        {# --- FLASH MESSAGES --- #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                </div>
            {% endfor %}
        {% endfor %}

        {# --- SEARCH + STATS --- #}
        <div class="card shadow mb-4 border-left-primary">
            <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center flex-wrap">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-search mr-2"></i>Rechercher un médicament
                </h6>
                <span class="badge badge-light text-primary border px-3">
                    {{ medicaments|length }} résultat{{ medicaments|length > 1 ? 's' : '' }}
                </span>
            </div>
            <div class="card-body">
                <form method="get" action="{{ path('app_titulaire_medicaments') }}" class="mb-0">
                    <div class="d-flex align-items-center flex-wrap">
                        <div class="search-box flex-grow-1 mr-3 mb-2 mb-md-0">
                            <i class="fas fa-search search-icon"></i>
                            <input type="text"
                                   name="q"
                                   class="form-control"
                                   placeholder="Ex: Doliprane, Amoxicilline, Smecta..."
                                   value="{{ search }}"
                                   autocomplete="off">
                        </div>
                        <button type="submit" class="btn btn-primary shadow-sm mr-2">
                            <i class="fas fa-search fa-sm mr-1"></i> Rechercher
                        </button>
                        {% if search %}
                            <a href="{{ path('app_titulaire_medicaments') }}" class="btn btn-outline-secondary shadow-sm">
                                <i class="fas fa-times fa-sm mr-1"></i> Réinitialiser
                            </a>
                        {% endif %}
                    </div>
                </form>
            </div>
        </div>

        {# --- MEDICATIONS TABLE --- #}
        <div class="card shadow mb-4">
            <div class="card-body p-0">
                {% if medicaments|length > 0 %}
                    <div class="table-responsive">
                        <table class="table med-table mb-0">
                            <thead>
                                <tr>
                                    <th>Médicament</th>
                                    <th>Pharmacie</th>
                                    <th>Code SKU</th>
                                    <th class="text-center">Stock</th>
                                    <th class="text-right">Prix unitaire</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for med in medicaments %}
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mr-3" style="width: 38px; height: 38px; min-width: 38px;">
                                                    <i class="fas fa-capsules text-primary"></i>
                                                </div>
                                                <span class="med-name">{{ med.nom_medicament }}</span>
                                            </div>
                                        </td>
                                        <td>
                                            {% if 'Centrale' in med.pharmacie %}
                                                <span class="pharmacy-badge pharmacy-a">
                                                    <i class="fas fa-store-alt"></i> {{ med.pharmacie }}
                                                </span>
                                            {% else %}
                                                <span class="pharmacy-badge pharmacy-b">
                                                    <i class="fas fa-store-alt"></i> {{ med.pharmacie }}
                                                </span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <span class="sku-tag">{{ med.code_sku }}</span>
                                        </td>
                                        <td class="text-center">
                                            {% if med.quantite_stock >= 200 %}
                                                <span class="stock-badge stock-high">
                                                    <i class="fas fa-check-circle mr-1"></i>{{ med.quantite_stock }} unités
                                                </span>
                                            {% elseif med.quantite_stock >= 100 %}
                                                <span class="stock-badge stock-medium">
                                                    <i class="fas fa-exclamation-circle mr-1"></i>{{ med.quantite_stock }} unités
                                                </span>
                                            {% else %}
                                                <span class="stock-badge stock-low">
                                                    <i class="fas fa-times-circle mr-1"></i>{{ med.quantite_stock }} unités
                                                </span>
                                            {% endif %}
                                        </td>
                                        <td class="text-right">
                                            <span class="price-tag">{{ med.prix|number_format(2, ',', ' ') }} DT</span>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center py-5">
                        <div class="empty-state-icon">
                            <i class="fas fa-pills fa-2x text-gray-300"></i>
                        </div>
                        {% if search %}
                            <p class="text-muted mb-1">Aucun médicament trouvé pour <strong>"{{ search }}"</strong></p>
                            <a href="{{ path('app_titulaire_medicaments') }}" class="btn btn-sm btn-outline-primary mt-2">
                                <i class="fas fa-redo mr-1"></i> Voir tous les médicaments
                            </a>
                        {% else %}
                            <p class="text-muted">Aucun médicament disponible pour le moment.</p>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% include 'titulaire/_partials/_ai_chat.html.twig' %}
{% endblock %}
