{% extends 'base.html.twig' %}

{% block title %}Paramètres - Clinic360{% endblock %}

{% block sidebar %}
    {% include 'titulaire/_partials/_sidebar.html.twig' %}
{% endblock %}

{% block topbar %}{% endblock %}

{% block body %}
    <div class="mt-4">
        <div class="d-sm-flex align-items-center justify-content-between mb-4">
            <div class="d-flex align-items-center">
                <a href="{{ path('app_titulaire_dashboard') }}" class="btn btn-link p-0 mr-3" title="Retour au tableau de bord">
                    <i class="fas fa-arrow-left fa-lg text-primary"></i>
                </a>
                <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
                    <i class="fas fa-cog mr-2"></i>Paramètres
                </h1>
            </div>
        </div>

        {# ── 2FA Card ────────────────────────────────────────────── #}
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex align-items-center">
                <i class="fas fa-shield-alt text-primary mr-2"></i>
                <h6 class="m-0 font-weight-bold text-primary">Authentification à deux facteurs (2FA)</h6>
            </div>
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        {% if app.user and app.user.isTotpAuthenticationEnabled() %}
                            <div class="d-flex align-items-center mb-2">
                                <span class="badge badge-success mr-2 py-1 px-2">
                                    <i class="fas fa-check-circle mr-1"></i> Activée
                                </span>
                                <span class="font-weight-bold text-gray-800">La 2FA est active sur votre compte</span>
                            </div>
                            <p class="text-muted small mb-0">
                                Votre compte est protégé par une application d'authentification (Google Authenticator, Authy, …).
                                Chaque connexion nécessitera un code à 6 chiffres en plus de votre mot de passe.
                            </p>
                        {% else %}
                            <div class="d-flex align-items-center mb-2">
                                <span class="badge badge-warning mr-2 py-1 px-2">
                                    <i class="fas fa-exclamation-triangle mr-1"></i> Désactivée
                                </span>
                                <span class="font-weight-bold text-gray-800">La 2FA n'est pas activée</span>
                            </div>
                            <p class="text-muted small mb-0">
                                Activez l'authentification à deux facteurs pour renforcer la sécurité de votre compte.
                                Vous aurez besoin d'une application comme <strong>Google Authenticator</strong> ou <strong>Authy</strong>.
                            </p>
                        {% endif %}
                    </div>
                    <div class="col-md-4 text-md-right mt-3 mt-md-0">
                        {% if app.user and app.user.isTotpAuthenticationEnabled() %}
                            <form method="post" action="{{ path('app_titulaire_2fa_disable') }}"
                                  onsubmit="return confirm('Êtes-vous sûr de vouloir désactiver la 2FA ?')">
                                <button type="submit" class="btn btn-outline-danger btn-sm font-weight-bold">
                                    <i class="fas fa-times-circle mr-1"></i> Désactiver la 2FA
                                </button>
                            </form>
                        {% else %}
                            <a href="{{ path('app_titulaire_2fa_setup') }}" class="btn btn-primary btn-sm font-weight-bold">
                                <i class="fas fa-qrcode mr-1"></i> Activer la 2FA
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% include 'titulaire/_partials/_ai_chat.html.twig' %}
{% endblock %}
