<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>{% block title %}SB Admin 2 - Dashboard{% endblock %}</title>

    <link href="{{ asset('backoffice/vendor/fontawesome-free/css/all.min.css') }}" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">

    <link href="{{ asset('backoffice/css/sb-admin-2.min.css') }}" rel="stylesheet">
</head>

<body id="page-top">

    <div id="wrapper">

        {{ include('medecin/_partials/_sidebar.html.twig') }}
        <div id="content-wrapper" class="d-flex flex-column">

            <div id="content">

                {{ include('medecin/_partials/_topbar.html.twig') }}
                <div class="container-fluid">
                    
                    {# Flash Messages for Success/Error alerts #}
                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                                {{ message }}
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                        {% endfor %}
                    {% endfor %}

                    {# This is where specific page content will be injected #}
                    {% block body %}{% endblock %}

                </div>
                </div>
            {{ include('medecin/_partials/_footer.html.twig') }}
            </div>
        </div>
    <a class="scroll-to-top rounded" href="#page-top">
        <i class="fas fa-angle-up"></i>
    </a>

    {{ include('medecin/_partials/_logout_modal.html.twig') }}

    <script src="{{ asset('backoffice/vendor/jquery/jquery.min.js') }}"></script>
    <script src="{{ asset('backoffice/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>

    <script src="{{ asset('backoffice/vendor/jquery-easing/jquery.easing.min.js') }}"></script>

    <script src="{{ asset('backoffice/js/sb-admin-2.min.js') }}"></script>

    {% block javascripts %}
        <script src="{{ asset('backoffice/vendor/chart.js/Chart.min.js') }}"></script>
        {% endblock %}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>