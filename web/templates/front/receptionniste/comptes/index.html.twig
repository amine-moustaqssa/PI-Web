{% extends 'front/receptionniste/base_receptionniste.html.twig' %}

{% block title %}Comptes Titulaires | Clinique 360{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-dark">Comptes Titulaires</h1>
            <p class="text-muted small">Liste de tous les utilisateurs avec le rôle Titulaire.</p>
        </div>
        <a href="{{ path('receptionniste_comptes_new') }}" class="btn btn-primary">
            <i class="fas fa-user-plus mr-1"></i> Ajouter un compte
        </a>
    </div>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for msg in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ msg }}
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Search bar #}
    <div class="row mb-4">
        <div class="col-md-6">
            <form method="get" action="{{ path('receptionniste_comptes') }}" class="input-group">
                <input type="text" name="q" class="form-control bg-dark text-white border-secondary"
                       placeholder="Rechercher par nom, prénom ou email..."
                       value="{{ search_query ?? '' }}">
                <div class="input-group-append">
                    <button class="btn btn-primary" type="submit"><i class="fas fa-search"></i></button>
                    {% if search_query %}
                        <a href="{{ path('receptionniste_comptes') }}" class="btn btn-secondary"><i class="fas fa-times"></i></a>
                    {% endif %}
                </div>
            </form>
        </div>
    </div>

    {# Table #}
    <div class="row">
        <div class="col-12">
            <div class="card shadow bg-dark-card">

                <div class="card-header py-3 bg-transparent border-secondary-custom">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-users mr-2"></i>Titulaires ({{ titulaires|length }})
                    </h6>
                </div>

                <div class="card-body">
                    {% if titulaires|length > 0 %}

                        <div class="table-responsive">
                            <table class="table table-dark table-hover align-middle" id="titulairesTable" width="100%" cellspacing="0">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Nom</th>
                                        <th>Prénom</th>
                                        <th>Email</th>
                                        <th>Adresse</th>
                                        <th>Code postal</th>
                                        <th>Vérifié</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for t in titulaires %}
                                        <tr>
                                            <td>{{ t.id }}</td>
                                            <td>{{ t.nom ?? '—' }}</td>
                                            <td>{{ t.prenom ?? '—' }}</td>
                                            <td>{{ t.email ?? '—' }}</td>
                                            <td>{{ t.adresse ?? '—' }}</td>
                                            <td>{{ t.codePostal ?? '—' }}</td>
                                            <td>
                                                {% if t.isVerified %}
                                                    <span class="badge badge-success">Oui</span>
                                                {% else %}
                                                    <span class="badge badge-warning">Non</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                    {% else %}

                        <div class="text-center py-5">
                            <i class="fas fa-users fa-3x mb-3" style="opacity:0.2; color:#ccc;"></i>
                            <p class="text-muted">Aucun titulaire trouvé.</p>
                        </div>

                    {% endif %}
                </div>
            </div>
        </div>
    </div>

</div>

<style>
.bg-dark-card {
    background-color: #242731 !important;
    border: 1px solid #2d303e;
}
.border-secondary-custom { border-bottom: 1px solid #2d303e !important; }
</style>

{% block javascripts %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap4.min.css">
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap4.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#titulairesTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json'
                },
                order: [[1, 'asc']],
                pageLength: 15
            });
        });
    </script>
{% endblock %}

{% endblock %}
