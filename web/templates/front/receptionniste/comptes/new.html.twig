{% extends 'front/receptionniste/base_receptionniste.html.twig' %}

{% block title %}Nouveau Compte | Clinique 360{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-dark">Créer un compte Titulaire</h1>
            <p class="text-muted small">Un mot de passe sera généré automatiquement par le système.</p>
        </div>
        <a href="{{ path('receptionniste_comptes') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left mr-1"></i> Retour
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow bg-dark-card">

                <div class="card-header py-3 bg-transparent border-secondary-custom">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-user-plus mr-2"></i>Informations du titulaire
                    </h6>
                </div>

                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.nom, null, {'label_attr': {'class': 'text-white'}}) }}
                                {{ form_widget(form.nom) }}
                                {{ form_errors(form.nom) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.prenom, null, {'label_attr': {'class': 'text-white'}}) }}
                                {{ form_widget(form.prenom) }}
                                {{ form_errors(form.prenom) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.email, null, {'label_attr': {'class': 'text-white'}}) }}
                            {{ form_widget(form.email) }}
                            {{ form_errors(form.email) }}
                        </div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                {{ form_label(form.adresse, null, {'label_attr': {'class': 'text-white'}}) }}
                                {{ form_widget(form.adresse) }}
                                {{ form_errors(form.adresse) }}
                            </div>
                            <div class="col-md-4 mb-3">
                                {{ form_label(form.codePostal, null, {'label_attr': {'class': 'text-white'}}) }}
                                {{ form_widget(form.codePostal) }}
                                {{ form_errors(form.codePostal) }}
                            </div>
                        </div>

                        <div class="alert alert-info mt-3">
                            <i class="fas fa-info-circle mr-1"></i>
                            Le mot de passe sera généré automatiquement et affiché après la création du compte.
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-check mr-1"></i> Créer le compte
                            </button>
                            <a href="{{ path('receptionniste_comptes') }}" class="btn btn-outline-secondary ml-2">Annuler</a>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>

</div>

<style>
.bg-dark-card {
    background-color: #242731 !important;
    border: 1px solid #2d303e;
}
.border-secondary-custom { border-bottom: 1px solid #2d303e !important; }
</style>
{% endblock %}
