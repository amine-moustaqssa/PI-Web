{% extends 'front/receptionniste/base_receptionniste.html.twig' %}

{% block title %}Compte créé — Imprimer la fiche | Clinique 360{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow bg-dark-card">

                <div class="card-body text-center py-5">

                    <div class="mb-4">
                        <i class="fas fa-check-circle fa-4x text-success"></i>
                    </div>

                    <h3 class="text-white mb-2">Compte créé avec succès !</h3>
                    <p class="text-muted mb-4">
                        Le compte de <strong class="text-white">{{ credentials.prenom }} {{ credentials.nom }}</strong> a été créé.<br>
                        Cliquez sur le bouton ci-dessous pour ouvrir la fiche PDF à imprimer.
                    </p>

                    <div class="mb-4">
                        <a href="{{ path('receptionniste_comptes_pdf') }}" target="_blank" class="btn btn-lg btn-primary px-5">
                            <i class="fas fa-print mr-2"></i> Ouvrir la fiche PDF
                        </a>
                    </div>

                    <a href="{{ path('receptionniste_comptes') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left mr-1"></i> Retour à la liste des comptes
                    </a>

                </div>
            </div>
        </div>
    </div>

</div>

<style>
.bg-dark-card {
    background-color: #242731 !important;
    border: 1px solid #2d303e;
}
</style>
{% endblock %}
