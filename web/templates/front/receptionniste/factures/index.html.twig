{% extends 'front/receptionniste/base_receptionniste.html.twig' %}

{% block title %}Factures & Paiements | Clinique 360{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-dark">Factures & Paiements</h1>
            <p class="text-muted small">Cette fonctionnalité sera bientôt disponible.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow bg-dark-card">
                <div class="card-body text-center py-5">
                    <i class="fas fa-file-invoice-dollar fa-3x mb-3" style="opacity:0.2; color:#ccc;"></i>
                    <p class="text-muted">Section en cours de développement.</p>
                </div>
            </div>
        </div>
    </div>

</div>

<style>
.bg-dark-card {
    background-color: #242731 !important;
    border: 1px solid #2d303e;
}
</style>
{% endblock %}
