{% extends 'front/receptionniste/base_receptionniste.html.twig' %}

{% block title %}Tableau de bord Réceptionniste | Clinique 360{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# Header #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-dark">Bonjour, {{ app.user.nom ?? 'Réceptionniste' }}</h1>
            <p class="text-muted small">Consultez les emplois du temps de tous les médecins.</p>
        </div>
        <div class="text-white bg-primary p-2 rounded shadow-sm">
            <i class="fas fa-calendar-day mr-2"></i>
            {{ "now"|date("d/m/Y") }}
        </div>
    </div>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for msg in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ msg }}
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Stats Cards #}
    <div class="row mb-4">

        {# Total médecins #}
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card shadow h-100 py-2 bg-dark-card border-left-primary">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                        Total Médecins
                    </div>
                    <div class="h5 mb-0 font-weight-bold text-white">
                        {{ totalMedecins ?? 0 }}
                    </div>
                </div>
            </div>
        </div>

        {# Médecins avec planning #}
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card shadow h-100 py-2 bg-dark-card border-left-success">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                        Médecins avec planning
                    </div>
                    <div class="h5 mb-0 font-weight-bold text-white">
                        {{ medecinsAvecPlanning ?? 0 }}
                    </div>
                </div>
            </div>
        </div>

        {# Total créneaux #}
        <div class="col-xl-4 col-md-12 mb-4">
            <div class="card shadow h-100 py-2 bg-dark-card border-left-warning">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                        Total Créneaux horaires
                    </div>
                    <div class="h5 mb-0 font-weight-bold text-white">
                        {{ totalDisponibilites ?? 0 }}
                    </div>
                </div>
            </div>
        </div>

    </div>

    {# Schedules Table #}
    <div class="row">
        <div class="col-12">
            <div class="card shadow bg-dark-card">

                <div class="card-header py-3 bg-transparent border-secondary-custom d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-calendar-alt mr-2"></i>Emplois du temps des médecins
                    </h6>
                </div>

                <div class="card-body">
                    {% if disponibilites is defined and disponibilites|length > 0 %}

                        <div class="table-responsive">
                            <table class="table table-dark table-hover align-middle" id="schedulesTable" width="100%" cellspacing="0">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Médecin</th>
                                        <th>Spécialité</th>
                                        <th>Jour</th>
                                        <th>Heure début</th>
                                        <th>Heure fin</th>
                                        <th>Récurrent</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for dispo in disponibilites %}
                                        <tr>
                                            <td>{{ dispo.id }}</td>
                                            <td>
                                                {% if dispo.medecin %}
                                                    Dr. {{ dispo.medecin.nom ?? '' }} {{ dispo.medecin.prenom ?? '' }}
                                                {% else %}
                                                    —
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if dispo.medecin and dispo.medecin.specialite is defined and dispo.medecin.specialite %}
                                                    {{ dispo.medecin.specialite.nom ?? '—' }}
                                                {% else %}
                                                    —
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if dispo.jourSemaine and jourNoms[dispo.jourSemaine] is defined %}
                                                    <span class="badge badge-info">{{ jourNoms[dispo.jourSemaine] }}</span>
                                                {% else %}
                                                    —
                                                {% endif %}
                                            </td>
                                            <td>{{ dispo.heureDebut ? dispo.heureDebut|date('H:i') : '—' }}</td>
                                            <td>{{ dispo.heureFin ? dispo.heureFin|date('H:i') : '—' }}</td>
                                            <td>
                                                {% if dispo.estRecurrent %}
                                                    <span class="badge badge-success">Oui</span>
                                                {% else %}
                                                    <span class="badge badge-secondary">Non</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                    {% else %}

                        <div class="text-center py-5">
                            <i class="fas fa-calendar-times fa-3x mb-3" style="opacity:0.2; color:#ccc;"></i>
                            <p class="text-muted">Aucun créneau horaire trouvé.</p>
                        </div>

                    {% endif %}
                </div>
            </div>
        </div>
    </div>

</div>

<style>
.bg-dark-card {
    background-color: #242731 !important;
    border: 1px solid #2d303e;
}
.border-left-primary { border-left: 4px solid #4e73df !important; }
.border-left-success { border-left: 4px solid #1cc88a !important; }
.border-left-warning { border-left: 4px solid #f6c23e !important; }
.border-secondary-custom { border-bottom: 1px solid #2d303e !important; }
.text-white { color: #ffffff !important; }
</style>

{% block javascripts %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap4.min.css">
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap4.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#schedulesTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json'
                },
                order: [[3, 'asc'], [4, 'asc']],
                pageLength: 15
            });
        });
    </script>
{% endblock %}

{% endblock %}
