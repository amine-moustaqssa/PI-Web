<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
        <meta name="description" content="" />
        <meta name="author" content="" />
        <title>{% block title %}Clinique App{% endblock %}</title>
        
        <link rel="icon" type="image/x-icon" href="{{ asset('front/assets/favicon.ico') }}" />
        
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css" rel="stylesheet" />
        
        <link href="{{ asset('front/css/styles.css') }}" rel="stylesheet" />
        
        <style>
            /* We include the color override here so it applies to the navbar links too */
            :root {
                --bs-primary: #4e73df; 
            }
            /* Custom hover effect for navbar links */
            .navbar-nav .nav-link {
                color: #5a5c69; /* Soft gray text */
                font-weight: 600;
                font-family: 'Poppins', sans-serif; /* Apply font to menu */
            }
            .navbar-nav .nav-link:hover, .navbar-nav .nav-link.active {
                color: #4e73df; /* Admin Blue on hover */
            }
        </style>
        
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="d-flex flex-column h-100" style="font-family: 'Poppins', sans-serif;">
        <main class="flex-shrink-0">
            
            <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
                <div class="container-fluid px-5">
                    
                    <a class="navbar-brand d-flex align-items-center" href="{{ path('app_home') }}">
                        <img src="{{ asset('img/logo.png') }}" alt="Clinique Logo" style="height: 45px; width: auto;">
                        <span class="ms-2 fw-bold text-primary" style="font-size: 1.35rem; letter-spacing: -0.5px;">Clinique 360</span>
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
                    
                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                            <li class="nav-item"><a class="nav-link active" href="{{ path('app_home') }}">Accueil</a></li>
                            
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#features">Services</a></li>
                            
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#about">À Propos</a></li>
                            
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#contact">Contact</a></li>
                            
                            <li class="nav-item">
                                {% if app.user %}
                                    <a class="nav-link btn btn-outline-danger px-3 ms-3" href="{{ path('app_logout') }}" style="color: #dc3545;">
                                        Déconnexion
                                    </a>
                                {% else %}
                                    <a class="nav-link btn btn-primary text-white px-3 ms-3" href="{{ path('app_login') }}">
                                        Se Connecter
                                    </a>
                                {% endif %}
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
            
            {% block body %}{% endblock %}
            
        </main>
        
        <footer class="bg-dark py-4 mt-auto">
            <div class="container px-5">
                <div class="row align-items-center justify-content-between flex-column flex-sm-row">
                    <div class="col-auto"><div class="small m-0 text-white">Copyright &copy; Clinique App 2023</div></div>
                    <div class="col-auto">
                        <a class="link-light small" href="#!">Privacy</a>
                        <span class="text-white mx-1">&middot;</span>
                        <a class="link-light small" href="#!">Terms</a>
                        <a class="link-light small" href="#!">Contact</a>
                    </div>
                </div>
            </div>
        </footer>
        
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
        <script src="{{ asset('front/js/scripts.js') }}"></script>
        
        {% block javascripts %}{% endblock %}
    </body>
</html>