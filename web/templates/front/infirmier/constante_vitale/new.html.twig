{% extends 'front/infirmier/base_infirmier.html.twig' %}

{% block title %}Ajouter une Constante Vitale | Clinique 360{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# Breadcrumb #}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0 m-0">
            <li class="breadcrumb-item"><a href="{{ path('infirmier_dashboard') }}">Tableau de bord</a></li>
            <li class="breadcrumb-item"><a href="{{ path('infirmier_consultation_index') }}">Consultations</a></li>
            <li class="breadcrumb-item"><a href="{{ path('infirmier_constante_index', {'id': consultation.id}) }}">Consultation #{{ consultation.id }}</a></li>
            <li class="breadcrumb-item active">Ajouter</li>
        </ol>
    </nav>

    <h1 class="h3 mb-4 text-dark">
        <i class="fas fa-plus-circle text-success mr-2"></i>
        Ajouter une Constante Vitale
    </h1>

    <div class="card shadow">
        <div class="card-header py-3" style="background-color: #f8f9fa; border-bottom: 1px solid #e0e0e0;">
            <h6 class="m-0 font-weight-bold" style="color: #0097a7;">
                Consultation #{{ consultation.id }}
                {% if consultation.medecin %}
                    — Dr. {{ consultation.medecin.nom ?? '' }} {{ consultation.medecin.prenom ?? '' }}
                {% endif %}
            </h6>
        </div>
        <div class="card-body">
            {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label font-weight-bold" style="color: #0097a7;">{{ form_label(form.type) }}</label>
                    {{ form_widget(form.type, {'attr': {'class': 'form-control', 'style': 'border: 1px solid #b0bec5;'}}) }}
                    {{ form_errors(form.type) }}
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label font-weight-bold" style="color: #0097a7;">{{ form_label(form.valeur) }}</label>
                    {{ form_widget(form.valeur, {'attr': {'class': 'form-control', 'style': 'border: 1px solid #b0bec5;'}}) }}
                    {{ form_errors(form.valeur) }}
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label font-weight-bold" style="color: #0097a7;">{{ form_label(form.unite) }}</label>
                    {{ form_widget(form.unite, {'attr': {'class': 'form-control', 'style': 'border: 1px solid #b0bec5;'}}) }}
                    {{ form_errors(form.unite) }}
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label font-weight-bold" style="color: #0097a7;">{{ form_label(form.date_prise) }}</label>
                    {{ form_widget(form.date_prise, {'attr': {'class': 'form-control', 'style': 'border: 1px solid #b0bec5;'}}) }}
                    {{ form_errors(form.date_prise) }}
                </div>
            </div>

            {{ form_rest(form) }}

            <div class="d-flex justify-content-between mt-4">
                <a href="{{ path('infirmier_constante_index', {'id': consultation.id}) }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left mr-1"></i> Annuler
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save mr-1"></i> Enregistrer
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

</div>



<script>
document.addEventListener('DOMContentLoaded', function() {
    const uniteMap = {
        'temperature': '°C',
        'frequence cardiaque': 'bpm',
        'pouls': 'bpm',
        'tension systolique': 'mmHg',
        'tension diastolique': 'mmHg',
        'pression arterielle moyenne': 'mmHg',
        'saturation o2': '%',
        'frequence respiratoire': 'resp/min',
        'glycemie a jeun': 'g/L',
        'glycemie': 'g/L',
        'glycemie postprandiale': 'g/L',
        'imc': 'kg/m²',
        'debit cardiaque': 'L/min',
        'diurese': 'mL/kg/h',
        'glasgow': '/15',
        'douleur': '/10',
        'hemoglobine': 'g/dL',
        'creatinine': 'mg/L',
        'potassium': 'mmol/L',
        'sodium': 'mmol/L',
        'plaquettes': '×10³/µL',
        'leucocytes': '×10³/µL'
    };

    const typeSelect = document.getElementById('constante_type_select') || document.querySelector('[id$="_type"]');
    const uniteInput = document.querySelector('[id$="_unite"]');

    if (typeSelect && uniteInput) {
        typeSelect.addEventListener('change', function() {
            const selected = this.value;
            if (uniteMap[selected]) {
                uniteInput.setAttribute('placeholder', uniteMap[selected]);
            } else {
                uniteInput.setAttribute('placeholder', '');
            }
        });
    }
});
</script>
{% endblock %}
