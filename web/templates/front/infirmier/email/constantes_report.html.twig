<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Rapport des Constantes Vitales - Clinique 360</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 0; padding: 0; background-color: #f4f4f4; }
        .container { max-width: 600px; margin: 0 auto; background: #ffffff; }
        .header { background: linear-gradient(135deg, #0097a7, #00bcd4); color: white; padding: 25px 30px; text-align: center; }
        .header h1 { font-size: 20px; margin: 0 0 8px 0; }
        .header p { font-size: 12px; opacity: 0.9; margin: 0; }
        .content { padding: 25px 30px; }
        .stats-row { display: table; width: 100%; margin-bottom: 15px; }
        .stat { display: table-cell; width: 25%; text-align: center; padding: 8px; }
        .stat-inner { border: 1px solid #e0e0e0; border-radius: 6px; padding: 10px 5px; }
        .stat-inner.info { border-top: 3px solid #36b9cc; }
        .stat-inner.warning { border-top: 3px solid #f6c23e; }
        .stat-inner.danger { border-top: 3px solid #e74a3b; }
        .stat-inner.success { border-top: 3px solid #1cc88a; }
        .stat-label { font-size: 10px; color: #888; text-transform: uppercase; font-weight: bold; }
        .stat-value { font-size: 20px; font-weight: bold; color: #333; }
        .summary-box { background: #f0f9fa; border: 1px solid #b2ebf2; border-radius: 8px; padding: 15px; margin-bottom: 20px; }
        .summary-box h3 { color: #00838f; font-size: 14px; margin: 0 0 10px 0; }
        table { width: 100%; border-collapse: collapse; }
        table th { background: #e0f7fa; color: #006064; padding: 8px; text-align: left; font-size: 11px; border-bottom: 2px solid #0097a7; }
        table td { padding: 8px; border-bottom: 1px solid #eee; font-size: 12px; }
        .normal { color: #1cc88a; font-weight: bold; }
        .warning { color: #f6c23e; font-weight: bold; }
        .critical { color: #e74a3b; font-weight: bold; }
        .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 10px; color: white; }
        .badge-success { background: #1cc88a; }
        .badge-warning { background: #f6c23e; color: #333; }
        .badge-danger { background: #e74a3b; }
        .badge-secondary { background: #858796; }
        .comparison-section { margin-top: 20px; }
        .comparison-section h3 { color: #e65100; font-size: 14px; margin-bottom: 10px; }
        .ref-badge { background: #e65100; color: white; padding: 2px 8px; border-radius: 10px; font-size: 10px; }
        .cmp-badge { background: #1565c0; color: white; padding: 2px 8px; border-radius: 10px; font-size: 10px; }
        .footer { background: #f8f9fa; padding: 15px 30px; text-align: center; font-size: 11px; color: #888; border-top: 2px solid #0097a7; }
        .note { background: #fffde7; border-left: 4px solid #ffc107; padding: 10px 15px; margin-top: 15px; font-size: 12px; color: #666; border-radius: 4px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>&#128202; Rapport des Constantes Vitales</h1>
            <p>Clinique 360 — {{ sentAt|date('d/m/Y à H:i') }}</p>
        </div>

        <div class="content">
            <p>Bonjour <strong>{{ recipientName }}</strong>,</p>
            <p style="color: #555; font-size: 13px;">
                Voici le rapport des constantes vitales 
                {% if consultationA %}pour la consultation de référence <strong>#{{ consultationA }}</strong>{% endif %}.
                {% if analysis.hasCritical is defined and analysis.hasCritical %}
                    <span style="color: #e74a3b;">&#9888; Des valeurs critiques ont été détectées.</span>
                {% endif %}
            </p>

            <!-- Statistiques -->
            <div class="stats-row">
                <div class="stat">
                    <div class="stat-inner info">
                        <div class="stat-label">Mesures</div>
                        <div class="stat-value">{{ constantes|length }}</div>
                    </div>
                </div>
                <div class="stat">
                    <div class="stat-inner success">
                        <div class="stat-label">Normales</div>
                        <div class="stat-value">{{ analysis.normalCount ?? 0 }}</div>
                    </div>
                </div>
                <div class="stat">
                    <div class="stat-inner warning">
                        <div class="stat-label">Attention</div>
                        <div class="stat-value">{{ analysis.warningCount ?? 0 }}</div>
                    </div>
                </div>
                <div class="stat">
                    <div class="stat-inner danger">
                        <div class="stat-label">Critiques</div>
                        <div class="stat-value">{{ analysis.criticalCount ?? 0 }}</div>
                    </div>
                </div>
            </div>

            <!-- Comparaison -->
            {% if comparisonData|length > 0 %}
            <div class="comparison-section">
                <h3>&#8644; Comparaison entre consultations</h3>
                {% if consultationA %}
                    <p style="font-size: 11px; color: #666;">
                        <span class="ref-badge">&#9733; Réf: #{{ consultationA }}</span>
                    </p>
                {% endif %}

                {% for consultId, cData in comparisonData %}
                    <div class="summary-box" style="{{ consultationA and consultId == consultationA ? 'border-color: #e65100; background: #fff8f0;' : '' }}">
                        <h3 style="color: {{ consultationA and consultId == consultationA ? '#e65100' : '#00838f' }};">
                            {% if consultationA and consultId == consultationA %}&#9733; {% endif %}
                            Consultation #{{ consultId }}
                            {% if consultationA and consultId == consultationA %} (Référence){% endif %}
                            — {{ cData.date }} — {{ cData.medecin }}
                        </h3>
                        <table>
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Valeur</th>
                                    <th>Unité</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for type, vals in cData.constantes %}
                                    <tr>
                                        <td><strong>{{ type|capitalize }}</strong></td>
                                        <td>
                                            {% set ref = null %}
                                            {% if vals.valeur is defined %}
                                                {{ vals.valeur }}
                                            {% endif %}
                                        </td>
                                        <td>{{ vals.unite ?? '' }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endfor %}
            </div>
            {% endif %}

            <div class="note">
                <strong>&#128206; PDF joint :</strong> Un rapport PDF détaillé est attaché en pièce jointe pour impression ou archivage.
            </div>

            <p style="font-size: 12px; color: #666; margin-top: 15px;">
                <strong>Date d'envoi :</strong> {{ sentAt|date('d/m/Y à H:i:s') }}
            </p>
        </div>

        <div class="footer">
            <strong>Clinique 360</strong> — Système de rapports automatiques<br>
            Envoyé via <strong>symfony/mailer</strong> — Bundle externe Symfony<br>
            Ce rapport est confidentiel. Ne pas transmettre sans autorisation.
        </div>
    </div>
</body>
</html>
