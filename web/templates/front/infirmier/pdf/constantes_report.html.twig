<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Rapport des Constantes Vitales - Clinique 360</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'DejaVu Sans', Arial, sans-serif;
            font-size: 11px;
            color: #333;
            line-height: 1.4;
        }

        /* En-tête */
        .header {
            background: linear-gradient(135deg, #0097a7, #00bcd4);
            color: white;
            padding: 20px 30px;
            margin-bottom: 20px;
        }
        .header h1 { font-size: 20px; margin-bottom: 5px; }
        .header p { font-size: 11px; opacity: 0.9; }
        .header .logo { font-size: 24px; font-weight: bold; }
        .header .date { float: right; text-align: right; font-size: 10px; margin-top: -40px; }

        /* Statistiques */
        .stats-row {
            display: table;
            width: 100%;
            margin-bottom: 15px;
        }
        .stat-card {
            display: table-cell;
            width: 25%;
            padding: 0 5px;
        }
        .stat-card-inner {
            border: 1px solid #ddd;
            border-radius: 5px;
            padding: 10px;
            text-align: center;
        }
        .stat-card-inner.info { border-left: 4px solid #36b9cc; }
        .stat-card-inner.primary { border-left: 4px solid #4e73df; }
        .stat-card-inner.warning { border-left: 4px solid #f6c23e; }
        .stat-card-inner.danger { border-left: 4px solid #e74a3b; }
        .stat-label { font-size: 9px; text-transform: uppercase; font-weight: bold; color: #888; }
        .stat-value { font-size: 18px; font-weight: bold; color: #333; }

        /* Sections */
        .section { margin-bottom: 20px; page-break-inside: avoid; }
        .section-title {
            background-color: #f8f9fa;
            border-bottom: 2px solid #0097a7;
            padding: 8px 15px;
            font-size: 13px;
            font-weight: bold;
            color: #0097a7;
            margin-bottom: 10px;
        }
        .section-title.orange { border-bottom-color: #ff9800; color: #e65100; }
        .section-title.purple { border-bottom-color: #7b1fa2; color: #7b1fa2; }

        /* Tableaux */
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 10px;
        }
        table th {
            background-color: #f8f9fa;
            color: #333;
            padding: 6px 8px;
            border: 1px solid #dee2e6;
            text-align: left;
            font-weight: bold;
        }
        table td {
            padding: 5px 8px;
            border: 1px solid #dee2e6;
        }
        .ref-row { background-color: rgba(230, 81, 0, 0.08); }
        .text-center { text-align: center; }
        .text-danger { color: #e74a3b; }
        .text-success { color: #1cc88a; }
        .text-warning { color: #f6c23e; }
        .text-info { color: #36b9cc; }
        .text-muted { color: #999; font-size: 9px; }
        .font-bold { font-weight: bold; }

        /* Badges alertes */
        .badge {
            display: inline-block;
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 9px;
            color: white;
            font-weight: bold;
        }
        .badge-success { background-color: #1cc88a; }
        .badge-warning { background-color: #f6c23e; color: #333; }
        .badge-danger { background-color: #e74a3b; }
        .badge-secondary { background-color: #858796; }
        .badge-orange { background-color: #e65100; }
        .badge-blue { background-color: #1565c0; }

        /* Pied de page */
        .footer {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            border-top: 2px solid #0097a7;
            padding: 8px 30px;
            font-size: 9px;
            color: #999;
            text-align: center;
        }

        .normal-val { color: #1cc88a; }
        .warning-val { color: #f6c23e; }
        .critical-val { color: #e74a3b; }
        .diff-up { color: #e74a3b; font-size: 9px; }
        .diff-down { color: #1cc88a; font-size: 9px; }
    </style>
</head>
<body>

    <!-- En-tête -->
    <div class="header">
        <div class="logo">&#9764; Clinique 360</div>
        <h1>Rapport des Constantes Vitales</h1>
        <p>Rapport généré automatiquement — {{ generatedAt|date('d/m/Y à H:i') }}</p>
        <div class="date">
            <strong>Date d'impression :</strong><br>
            {{ generatedAt|date('d/m/Y H:i:s') }}
        </div>
    </div>

    <!-- Statistiques résumé -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-card-inner info">
                <div class="stat-label">Total Mesures</div>
                <div class="stat-value">{{ constantes|length }}</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-inner primary">
                <div class="stat-label">Types distincts</div>
                <div class="stat-value">
                    {% set typesSet = [] %}
                    {% for c in constantes %}
                        {% if c.type not in typesSet %}
                            {% set typesSet = typesSet|merge([c.type]) %}
                        {% endif %}
                    {% endfor %}
                    {{ typesSet|length }}
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-inner warning">
                <div class="stat-label">Consultations</div>
                <div class="stat-value">{{ comparisonData|keys|length }}</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-inner danger">
                <div class="stat-label">Alertes critiques</div>
                <div class="stat-value">{{ analysis.criticalCount }}</div>
            </div>
        </div>
    </div>

    <!-- Tableau comparatif -->
    {% if comparisonData|keys|length >= 1 %}
    <div class="section">
        <div class="section-title orange">
            &#8644; Comparaison entre consultations
            {% if consultationA %}
                <span class="badge badge-orange" style="margin-left: 10px;">Réf: Consultation #{{ consultationA }}</span>
            {% endif %}
        </div>

        {% if comparisonData|keys|length >= 2 %}
        <p style="font-size: 10px; margin-bottom: 8px; color: #666;">
            <span class="badge badge-orange">&#9733; Consultation A (référence)</span> &nbsp;
            <span class="badge badge-blue">&#8644; Consultations comparées</span> &nbsp;
            <span style="color: #e74a3b;">&#8593; Hausse</span> &nbsp;
            <span style="color: #1cc88a;">&#8595; Baisse</span> par rapport à A
        </p>
        {% endif %}

        <table>
            <thead>
                <tr style="background-color: #fff3e0;">
                    <th style="color: #e65100; min-width: 100px;">Consultation</th>
                    <th style="color: #e65100;">Date</th>
                    <th style="color: #e65100;">Médecin</th>
                    {% set allTypes = [] %}
                    {% for consultId, cData in comparisonData %}
                        {% for t, val in cData.constantes %}
                            {% if t not in allTypes %}
                                {% set allTypes = allTypes|merge([t]) %}
                            {% endif %}
                        {% endfor %}
                    {% endfor %}
                    {% for t in allTypes %}
                        <th class="text-center" style="color: #00838f;">{{ t|capitalize }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% set refData = comparisonData[consultationA] ?? null %}
                {% for consultId, cData in comparisonData %}
                    {% set isRef = (consultationA and consultId == consultationA) %}
                    <tr class="{{ isRef ? 'ref-row' : '' }}">
                        <td class="font-bold" style="color: {{ isRef ? '#e65100' : '#0097a7' }};">
                            {% if isRef %}&#9733; {% endif %}#{{ consultId }}{% if isRef %} (A){% endif %}
                        </td>
                        <td>{{ cData.date }}</td>
                        <td>{{ cData.medecin }}</td>
                        {% for t in allTypes %}
                            <td class="text-center">
                                {% if cData.constantes[t] is defined %}
                                    {% set ref = references[t] is defined ? references[t] : null %}
                                    {% set val = cData.constantes[t].valeur %}
                                    {% if ref %}
                                        {% if val < ref.critical_low or val > ref.critical_high %}
                                            <span class="font-bold critical-val">{{ val }}</span>
                                        {% elseif val < ref.normal_low or val > ref.normal_high %}
                                            <span class="font-bold warning-val">{{ val }}</span>
                                        {% else %}
                                            <span class="font-bold normal-val">{{ val }}</span>
                                        {% endif %}
                                    {% else %}
                                        <span class="font-bold">{{ val }}</span>
                                    {% endif %}
                                    <br><span class="text-muted">{{ cData.constantes[t].unite }}</span>
                                    {% if not isRef and refData and refData.constantes[t] is defined %}
                                        {% set refVal = refData.constantes[t].valeur %}
                                        {% set diff = val - refVal %}
                                        {% if diff > 0 %}
                                            <br><span class="diff-up">&#8593; +{{ diff|number_format(1) }}</span>
                                        {% elseif diff < 0 %}
                                            <br><span class="diff-down">&#8595; {{ diff|number_format(1) }}</span>
                                        {% else %}
                                            <br><span class="text-info">= 0</span>
                                        {% endif %}
                                    {% endif %}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                        {% endfor %}
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}

    <!-- Détail des mesures -->
    <div class="section">
        <div class="section-title purple">
            &#9638; Détail des mesures ({{ constantes|length }})
        </div>
        <table>
            <thead>
                <tr style="background-color: #f3e5f5;">
                    <th style="color: #7b1fa2;">Consultation</th>
                    <th style="color: #7b1fa2;">Type</th>
                    <th style="color: #7b1fa2;">Valeur</th>
                    <th style="color: #7b1fa2;">Unité</th>
                    <th style="color: #7b1fa2;">Statut</th>
                    <th style="color: #7b1fa2;">Date de prise</th>
                </tr>
            </thead>
            <tbody>
                {% for key, constante in constantes %}
                    {% set alert = analysis.alerts[key] ?? null %}
                    <tr style="{{ alert and alert.level == 'critical' ? 'background-color: rgba(220, 53, 69, 0.1);' : (alert and alert.level == 'warning' ? 'background-color: rgba(255, 193, 7, 0.08);' : '') }}">
                        <td>#{{ constante.consultationId.id }}</td>
                        <td class="font-bold">{{ constante.type }}</td>
                        <td>
                            <span class="font-bold {% if alert and alert.level == 'critical' %}critical-val{% elseif alert and alert.level == 'warning' %}warning-val{% else %}normal-val{% endif %}">
                                {{ constante.valeur }}
                            </span>
                        </td>
                        <td>{{ constante.unite }}</td>
                        <td>
                            {% if alert %}
                                <span class="badge badge-{{ alert.level == 'normal' ? 'success' : (alert.level == 'warning' ? 'warning' : 'danger') }}">
                                    {{ alert.level == 'normal' ? 'Normal' : (alert.level == 'warning' ? 'Attention' : 'CRITIQUE') }}
                                </span>
                            {% else %}
                                <span class="badge badge-secondary">N/A</span>
                            {% endif %}
                        </td>
                        <td>{{ constante.datePrise ? constante.datePrise|date('d/m/Y H:i') : '—' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Pied de page -->
    <div class="footer">
        Clinique 360 &mdash; Rapport généré le {{ generatedAt|date('d/m/Y à H:i:s') }} | 
        Ce document est confidentiel et destiné uniquement au personnel médical autorisé.
        <br>Généré avec <strong>dompdf/dompdf</strong> — Bundle externe Symfony
    </div>

</body>
</html>
