<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Rapport médical - Clinique 360</title>
    <style>
        /* ========== STYLES GÉNÉRAUX ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            line-height: 1.6;
            color: #2c3e50;
            background: #fff;
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            background: white;
            padding: 30px;
            position: relative;
            box-shadow: 0 0 20px rgba(0,0,0,0.05);
        }

        /* ========== EN-TÊTE ========== */
        .header {
            margin-bottom: 25px;
            border-bottom: 3px solid #1a5f7a;
            padding-bottom: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .hospital-info h1 {
            color: #1a5f7a;
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 3px;
        }

        .hospital-info h2 {
            color: #34495e;
            font-size: 16px;
            font-weight: 400;
            margin-bottom: 5px;
        }

        .hospital-details {
            font-size: 11px;
            color: #7f8c8d;
            line-height: 1.3;
        }

        .document-info {
            text-align: right;
            background: #f0f7fc;
            padding: 10px 15px;
            border-radius: 6px;
            border-left: 4px solid #1a5f7a;
        }

        .document-info p {
            margin: 3px 0;
            font-size: 12px;
        }

        .document-info strong {
            color: #1a5f7a;
        }

        .fallback-badge {
            background: #f39c12;
            color: white;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 9px;
            display: inline-block;
            margin-top: 3px;
        }

        /* ========== TITRE ========== */
        .document-title {
            text-align: center;
            margin: 20px 0 25px;
            padding: 15px;
            background: linear-gradient(135deg, #f8f9fa, #e9ecef);
            border-radius: 8px;
            border-left: 6px solid #1a5f7a;
            border-right: 6px solid #1a5f7a;
        }

        .document-title h3 {
            color: #1a5f7a;
            font-size: 22px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 3px;
        }

        .document-title p {
            color: #5d6d7e;
            font-size: 13px;
        }

        /* ========== SECTIONS ========== */
        .section {
            background: #fff;
            border: 1px solid #e5e9f0;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.03);
        }

        .section-title {
            color: #1a5f7a;
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 15px;
            padding-bottom: 8px;
            border-bottom: 2px solid #d0e0f0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-title span {
            background: #1a5f7a;
            color: white;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

        /* ========== GRILLE INFORMATIONS ========== */
        .grid-2 {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
        }

        .grid-3 {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
        }

        .info-card {
            background: #f9fcff;
            padding: 12px 15px;
            border-radius: 8px;
            border-left: 4px solid #1a5f7a;
        }

        .info-label {
            font-weight: 600;
            color: #5a6b7c;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            margin-bottom: 4px;
        }

        .info-value {
            color: #1e2b39;
            font-size: 15px;
            font-weight: 500;
        }

        /* ========== ALLERGIES ========== */
        .allergies-section {
            margin-top: 15px;
            padding: 12px;
            background: #fff5f5;
            border-radius: 8px;
            border-left: 4px solid #e74c3c;
        }

        .allergies-title {
            font-weight: 600;
            color: #c0392b;
            font-size: 13px;
            margin-bottom: 8px;
        }

        .allergies-container {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .allergy-badge {
            background: #fdeded;
            color: #c0392b;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
            border: 1px solid #f5c6c6;
        }

        /* ========== CONTENU MÉDICAL ========== */
        .medical-box {
            background: #f9fcff;
            border-radius: 8px;
            padding: 18px;
            border: 1px solid #d6e4f0;
        }

        .medical-box h5 {
            color: #1a5f7a;
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 10px;
            padding-bottom: 5px;
            border-bottom: 1px dashed #bcd0e7;
        }

        .medical-text {
            font-size: 14px;
            line-height: 1.7;
            color: #2c3e50;
            background: white;
            padding: 15px;
            border-radius: 6px;
            border: 1px solid #e9ecef;
        }

        .conclusion-box {
            background: #eef7fa;
            border-left: 4px solid #1a5f7a;
            padding: 18px;
            border-radius: 0 8px 8px 0;
            margin-top: 10px;
        }

        .conclusion-box h5 {
            color: #1a5f7a;
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        /* ========== BADGE SPÉCIALITÉ ========== */
        .specialite-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            background-color: #e9ecef;
            color: #495057;
            border: 1px solid #ced4da;
        }

        /* ========== SIGNATURE ========== */
        .doctor-section {
            margin-top: 30px;
            padding: 20px;
            background: #f2f6fa;
            border-radius: 10px;
            border: 1px solid #d0ddee;
        }

        .signature-container {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-wrap: wrap;
        }

        .doctor-details {
            flex: 1;
        }

        .doctor-details h5 {
            color: #1a5f7a;
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 12px;
        }

        .doctor-details p {
            margin: 5px 0;
            color: #2c3e50;
        }

        .signature-box {
            text-align: center;
            min-width: 220px;
            padding: 10px 15px;
            background: white;
            border-radius: 8px;
            border: 1px dashed #1a5f7a;
        }

        .signature-line {
            padding: 15px 0 5px;
            border-top: 2px solid #1a5f7a;
            width: 180px;
            margin: 10px auto 0;
        }

        .signature-name {
            font-weight: 600;
            color: #1a5f7a;
            font-size: 15px;
        }

        .stamp {
            margin-top: 10px;
            font-size: 11px;
            color: #34495e;
            opacity: 0.8;
        }

        /* ========== MENTIONS LÉGALES ========== */
        .legal-footer {
            margin-top: 30px;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 8px;
            font-size: 9px;
            color: #6c757d;
            text-align: center;
            border: 1px solid #dee2e6;
        }

        .confidential-badge {
            color: #c0392b;
            font-weight: bold;
            font-size: 11px;
            border: 1px solid #c0392b;
            display: inline-block;
            padding: 3px 12px;
            border-radius: 20px;
            margin-bottom: 8px;
            background: #fff5f5;
        }

        /* ========== PIED DE PAGE ========== */
        .page-footer {
            margin-top: 15px;
            padding-top: 10px;
            border-top: 1px solid #dee2e6;
            text-align: center;
            font-size: 9px;
            color: #95a5a6;
        }

        /* ========== UTILITAIRES ========== */
        .mt-2 { margin-top: 10px; }
        .mb-2 { margin-bottom: 10px; }
        .text-right { text-align: right; }
        .text-center { text-align: center; }

        /* ========== IMPRESSION ========== */
        @media print {
            body { padding: 0; }
            .container { padding: 20px; box-shadow: none; }
            .doctor-section { break-inside: avoid; }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- ========== EN-TÊTE ========== -->
        <div class="header">
            <div class="hospital-info">
                <h1>CLINIQUE 360</h1>
                <h2>Service de Médecine</h2>
                <div class="hospital-details">
                    <p>123 Avenue de la Santé - Tunis, Tunisie 1000</p>
                    <p>Tél: +216 71 000 000 - Email: contact@clinique360.tn</p>
                </div>
            </div>
            <div class="document-info">
                <p><strong>Réf:</strong> RPT-{{ rapport.id }}-{{ rapport.dateCreation|date('Ymd') }}</p>
                <p><strong>Émis le:</strong> {{ date_generation|date('d/m/Y') }}</p>
                {% if fallback is defined and fallback %}
                    <span class="fallback-badge">Copie locale</span>
                {% endif %}
            </div>
        </div>

        <!-- ========== TITRE ========== -->
        <div class="document-title">
            <h3>RAPPORT MÉDICAL</h3>
            <p>Document confidentiel protégé par le secret médical</p>
        </div>

        <!-- ========== SECTION PATIENT ========== -->
        <div class="section">
            <div class="section-title">
                <span>👤</span> INFORMATIONS PATIENT
            </div>
            
            <div class="grid-3">
                <div class="info-card">
                    <div class="info-label">Nom complet</div>
                    <div class="info-value">{{ profil.nom|upper }} {{ profil.prenom|capitalize }}</div>
                </div>
                
                <div class="info-card">
                    <div class="info-label">Date de naissance</div>
                    <div class="info-value">{{ profil.dateNaissance|date('d/m/Y') }} ({{ date().diff(profil.dateNaissance).y }} ans)</div>
                </div>
                
                <div class="info-card">
                    <div class="info-label">Contact urgence</div>
                    <div class="info-value">{{ profil.contactUrgence }}</div>
                </div>
                
                <div class="info-card">
                    <div class="info-label">Médecin traitant</div>
                    <div class="info-value">Dr. {{ medecin.prenom }} {{ medecin.nom }}</div>
                </div>
            </div>

            <!-- Allergies -->
            {% if dossier.allergies is not empty %}
            <div class="allergies-section">
                <div class="allergies-title">⚠️ ALLERGIES CONNUES</div>
                <div class="allergies-container">
                    {% for allergie in dossier.allergies %}
                        <span class="allergy-badge">{{ allergie }}</span>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            <!-- Antécédents -->
            {% if dossier.antecedents %}
            <div class="mt-2">
                <div class="info-label" style="margin-bottom: 5px;">📜 ANTÉCÉDENTS</div>
                <div class="medical-text" style="background: #f8f9fa; padding: 10px;">
                    {{ dossier.antecedents|nl2br }}
                </div>
            </div>
            {% endif %}
        </div>

        <!-- ========== SECTION CONSULTATION ========== -->
        <div class="section">
            <div class="section-title">
                <span>📅</span> DÉTAILS DE LA CONSULTATION
            </div>
            
            <div class="grid-3">
                <div class="info-card">
                    <div class="info-label">Date</div>
                    <div class="info-value">{{ rapport.dateCreation|date('d/m/Y') }}</div>
                </div>
                
                <div class="info-card">
                    <div class="info-label">Heure</div>
                    <div class="info-value">{{ rapport.dateCreation|date('H:i') }}</div>
                </div>
                
                <div class="info-card">
                    <div class="info-label">Département</div>
                    <div class="info-value">
                        {% if departement %}
                            {{ departement.nom }}
                        {% else %}
                            Médecine
                        {% endif %}
                    </div>
                </div>
                
                <div class="info-card">
                    <div class="info-label">Spécialité</div>
                    <div class="info-value">
                        {% if specialite %}
                            <span class="specialite-badge">{{ specialite.nom }}</span>
                        {% else %}
                            Généraliste
                        {% endif %}
                    </div>
                </div>
                
                <div class="info-card">
                    <div class="info-label">Médecin</div>
                    <div class="info-value">Dr. {{ medecin.prenom }} {{ medecin.nom }}</div>
                </div>
                
                <div class="info-card">
                    <div class="info-label">ID Rapport</div>
                    <div class="info-value">#{{ rapport.id }}</div>
                </div>
            </div>
        </div>

        <!-- ========== SECTION CLINIQUE ========== -->
        <div class="section">
            <div class="section-title">
                <span>🔬</span> EXAMEN CLINIQUE
            </div>
            
            <div class="medical-box">
                <h5>📝 Observations</h5>
                <div class="medical-text">
                    {{ rapport.contenu|nl2br }}
                </div>
            </div>
        </div>

        <!-- ========== CONCLUSION ========== -->
        <div class="section">
            <div class="section-title">
                <span>📌</span> CONCLUSION
            </div>
            
            <div class="conclusion-box">
                {{ rapport.conclusion|nl2br }}
            </div>
        </div>

        <!-- ========== SIGNATURE ========== -->
        <div class="doctor-section">
            <div class="signature-container">
                <div class="doctor-details">
                    <h5>MÉDECIN AYANT ÉTABLI LE RAPPORT</h5>
                    <p><strong>Dr. {{ medecin.prenom }} {{ medecin.nom }}</strong></p>
                    
                    {% if specialite %}
                        <p>Spécialité : {{ specialite.nom }}</p>
                    {% else %}
                        <p>Spécialité : Généraliste</p>
                    {% endif %}
                    
                    {% if medecin.matricule %}
                        <p>Matricule : {{ medecin.matricule }}</p>
                    {% endif %}
                    
                    <p>Email : {{ medecin.email }}</p>
                </div>
                
                <div class="signature-box">
                    <div class="signature-line">
                        <div class="signature-name">Dr. {{ medecin.prenom }} {{ medecin.nom }}</div>
                    </div>
                    <p style="font-size: 11px; margin-top: 5px;">Signature du médecin</p>
                    <div class="stamp">
                        {% if specialite %}
                            ⚕️ {{ specialite.nom|upper }} ⚕️
                        {% else %}
                            ⚕️ MÉDECINE ⚕️
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <!-- ========== MENTIONS LÉGALES ========== -->
        <div class="legal-footer">
            <div class="confidential-badge">CONFIDENTIEL - SECRET MÉDICAL</div>
            <p>Document protégé par le secret médical - {{ date_generation|date('d/m/Y H:i') }}</p>
        </div>

        <!-- ========== PIED DE PAGE ========== -->
        <div class="page-footer">
            <span>CLINIQUE 360 - Document généré le {{ date_generation|date('d/m/Y') }}</span>
        </div>
    </div>
</body>
</html>