{% extends 'front/medecin/base_medecin.html.twig' %}

{% block title %}Historique des rapports médicaux{% endblock %}

{% block body %}
<div class="container-fluid">

    <!-- Titre + retour -->
    <div class="d-flex align-items-center mb-4">
        <a href="{{ path('medecin_dossier_show', { id: profil.id }) }}"
           class="btn btn-sm btn-light shadow-sm mr-3">
            <i class="fas fa-arrow-left"></i>
        </a>

        <h1 class="h3 text-gray-800 mb-0">
            Historique des rapports – {{ profil.nom }} {{ profil.prenom }}
        </h1>
    </div>

    <div class="card shadow">
        <div class="card-body">

            <!-- Recherche + tri + ajouter -->
            <div class="row mb-3 align-items-center">
                <div class="col-md-4">
                    <input type="text"
                           id="searchInput"
                           class="form-control"
                           placeholder="🔍 Rechercher dans les rapports...">
                </div>

                <div class="col-md-3">
                    <select id="sortDate" class="form-control">
                        <option value="desc">📅 Plus récent</option>
                        <option value="asc">📅 Plus ancien</option>
                    </select>
                </div>

                <div class="col-md-5 text-right">
                    <a href="{{ path('medecin_rapport_medical_new', { id: dossier.id }) }}"
                       class="btn btn-primary">
                        <i class="fas fa-plus"></i> Nouveau rapport
                    </a>
                </div>
            </div>

            {% if rapports|length > 0 %}
                <table class="table table-bordered table-hover" id="rapportTable">
                    <thead class="thead-light">
                        <tr>
                            <th>Date</th>
                            <th>Contenu</th>
                            <th>Conclusion</th>
                            <th>URL PDF</th>  {# Nouvelle colonne #}
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for rapport in rapports %}
                            <tr data-date="{{ rapport.dateCreation|date('Y-m-d') }}">
                                <td>{{ rapport.dateCreation|date('d/m/Y') }}</td>

                                <td class="contenu">{{ rapport.contenu }}</td>
                                <td class="conclusion">{{ rapport.conclusion }}</td>

                                <td class="url_pdf">
                                    {% if rapport.urlPdf %}
                                        <a href="{{ rapport.urlPdf }}" target="_blank">Voir PDF</a>
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>

                                <td class="text-center">
                                    <a href="{{ path('medecin_rapport_medical_edit', { id: rapport.id }) }}"
                                       class="btn btn-sm btn-info">
                                        <i class="fas fa-edit"></i>
                                    </a>

                                    <form method="post"
                                          action="{{ path('medecin_rapport_medical_delete', { id: rapport.id }) }}"
                                          style="display:inline;">
                                        <button type="submit" class="btn btn-sm btn-secondary ml-1 delete-btn">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <div class="alert alert-info text-center">
                    Aucun rapport médical n’a encore été ajouté.
                </div>
            {% endif %}

        </div>
    </div>

</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
document.addEventListener('DOMContentLoaded', function () {
    // ----------------------
    // Recherche + Tri
    // ----------------------
    const searchInput = document.getElementById('searchInput');
    const sortSelect = document.getElementById('sortDate');
    const tableBody = document.querySelector('#rapportTable tbody');

    function filterAndSort() {
        const search = searchInput.value.toLowerCase();
        const rows = Array.from(tableBody.querySelectorAll('tr'));

        rows.forEach(row => {
            const contenu = row.querySelector('.contenu').innerText.toLowerCase();
            const conclusion = row.querySelector('.conclusion').innerText.toLowerCase();
            const urlPdf = row.querySelector('.url_pdf').innerText.toLowerCase();

            row.style.display =
                contenu.includes(search) || conclusion.includes(search) || urlPdf.includes(search)
                    ? ''
                    : 'none';
        });

        rows.sort((a, b) => {
            const dateA = new Date(a.dataset.date);
            const dateB = new Date(b.dataset.date);
            return sortSelect.value === 'asc' ? dateA - dateB : dateB - dateA;
        });

        rows.forEach(row => tableBody.appendChild(row));
    }

    searchInput.addEventListener('keyup', filterAndSort);
    sortSelect.addEventListener('change', filterAndSort);

    // ----------------------
    // Confirmation suppression SweetAlert2
    // ----------------------
    document.querySelectorAll('.delete-btn').forEach(function(button) {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            let form = this.closest('form');

            Swal.fire({
                title: 'Êtes-vous sûr ?',
                text: "Cette action est irréversible !",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#6c757d', // gris neutre
                cancelButtonColor: '#adb5bd',  // gris clair
                confirmButtonText: 'Oui, supprimer !',
                cancelButtonText: 'Annuler'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });
    });

    // ----------------------
    // Toast pour flash messages
    // ----------------------
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: '{{ type }}' == 'success' ? 'success' : 'error',
                title: '{{ message|e('js') }}',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true
            });
        {% endfor %}
    {% endfor %}
});
</script>
{% endblock %}
