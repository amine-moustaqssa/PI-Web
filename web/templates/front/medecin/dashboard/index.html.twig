{# templates/front/medecin/base_medecin.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Clinic360 - Médecin{% endblock %}</title>

    {# Bootstrap et icônes #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    {# Styles personnalisés #}
    <link href="{{ asset('front/css/styles.css') }}" rel="stylesheet">
    
    {% block stylesheets %}{% endblock %}
</head>
<body class="d-flex">

    {# Sidebar #}
    <nav id="sidebar" class="bg-dark text-white vh-100 p-3 position-fixed" style="width: 220px;">
        <div class="text-center mb-4">
            <a href="{{ path('medecin_dashboard') }}" class="text-decoration-none text-white">
                <img src="{{ asset('front/assets/logo.png') }}" width="50" class="rounded-circle mb-2">
                <div>Clinic360</div>
            </a>
        </div>

        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link text-white {{ app.request.get('_route') == 'medecin_dashboard' ? 'active' : '' }}"
                   href="{{ path('medecin_dashboard') }}">
                    <i class="fas fa-chart-line me-2"></i> Tableau de bord
                </a>
            </li>

            <li class="nav-item mt-3">
                <span class="text-muted small">Activité Médicale</span>
            </li>

            <li class="nav-item">
                <a class="nav-link text-white" href="#">
                    <i class="fas fa-user-minus me-2"></i> Consultation
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-white" href="#">
                    <i class="fas fa-calendar-alt me-2"></i> Rendez-vous
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-white {{ app.request.get('_route') starts with 'medecin_dossier' or app.request.get('_route') == 'medecin_profils_list' ? 'active' : '' }}"
                   href="{{ path('medecin_profils_list') }}">
                    <i class="fas fa-folder-open me-2"></i> Dossier Clinique
                </a>
            </li>

            <li class="nav-item mt-3">
                <span class="text-muted small">Administrative</span>
            </li>

            <li class="nav-item">
                <a class="nav-link text-white" href="#">
                    <i class="fas fa-truck me-2"></i> Disponibilité
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-white" href="#">
                    <i class="fas fa-hospital me-2"></i> Spécialité
                </a>
            </li>

            <li class="nav-item mt-4">
                {% if app.user %}
                    <a class="nav-link btn btn-outline-danger w-100" href="{{ path('app_logout') }}">
                        <i class="fas fa-sign-out-alt me-2"></i> Déconnexion
                    </a>
                {% endif %}
            </li>
        </ul>
    </nav>

    {# Contenu principal #}
    <div class="flex-grow-1 ms-220" style="margin-left: 220px;">
        <main class="p-4">

            {# Flash messages #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>
    </div>

    {# Footer #}
    <footer class="bg-dark text-white py-3 mt-auto text-center" style="margin-left: 220px;">
        &copy; 2026 Clinic360. Tous droits réservés.
    </footer>

    {# JS Bootstrap et FontAwesome #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    <script src="{{ asset('front/js/scripts.js') }}"></script>

    {% block javascripts %}{% endblock %}

    <style>
        #sidebar .nav-link.active {
            background-color: rgba(85, 70, 255, 0.1);
            color: #5546FF !important;
            font-weight: 500;
        }

        #sidebar .nav-link:hover {
            background-color: rgba(255, 255, 255, 0.05);
        }

        .ms-220 {
            margin-left: 220px;
        }
    </style>
</body>
</html>
