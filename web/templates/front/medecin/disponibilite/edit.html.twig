{% extends 'front/medecin/base_medecin.html.twig' %}

{% block title %}Modifier Créneau | Clinic360{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# Page Heading #}
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-edit mr-2"></i>Modifier le créneau</h1>
        <a href="{{ path('medecin_disponibilite_index') }}" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm">
            <i class="fas fa-arrow-left fa-sm text-white-50 mr-1"></i> Retour à la liste
        </a>
    </div>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show shadow-sm" role="alert">
                {{ message }}
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% set jours = {1: 'Lundi', 2: 'Mardi', 3: 'Mercredi', 4: 'Jeudi', 5: 'Vendredi', 6: 'Samedi', 7: 'Dimanche'} %}

    <div class="row justify-content-center">
        {# Colonne Formulaire (Centrée) #}
        <div class="col-xl-10 col-lg-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-calendar-check mr-1"></i>
                        Modifier le créneau — {{ jours[disponibilite.jourSemaine] | default('') }}
                    </h6>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'action': path('medecin_disponibilite_edit', {id: disponibilite.id}), 'method': 'POST', 'attr': {'novalidate': 'novalidate'}}) }}

                    {% if form.vars.errors|length > 0 %}
                        <div class="alert alert-danger">
                            {{ form_errors(form) }}
                        </div>
                    {% endif %}

                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label class="font-weight-bold text-gray-700">
                                    <i class="fas fa-calendar mr-1 text-primary"></i> Date de la disponibilité
                                </label>
                                {{ form_widget(form.dateSpecifique, {'attr': {'class': 'form-control'}}) }}
                                <div class="text-danger small mt-1">{{ form_errors(form.dateSpecifique) }}</div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold text-gray-700">
                                    <i class="fas fa-play text-success mr-1"></i> Heure de début
                                </label>
                                {{ form_widget(form.heureDebut, {'attr': {'class': 'form-control'}}) }}
                                <div class="text-danger small mt-1">{{ form_errors(form.heureDebut) }}</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold text-gray-700">
                                    <i class="fas fa-stop text-danger mr-1"></i> Heure de fin
                                </label>
                                {{ form_widget(form.heureFin, {'attr': {'class': 'form-control'}}) }}
                                <div class="text-danger small mt-1">{{ form_errors(form.heureFin) }}</div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-left-info shadow-sm py-2 mb-3">
                        <div class="card-body py-2">
                            <div class="form-check">
                                {{ form_widget(form.estRecurrent, {'attr': {'class': 'form-check-input'}}) }}
                                <label class="form-check-label font-weight-bold text-primary small" for="{{ form.estRecurrent.vars.id }}">
                                    <i class="fas fa-sync-alt mr-2"></i> Répéter ce créneau chaque semaine
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="text-danger small mt-1">{{ form_errors(form.estRecurrent) }}</div>

                    <hr>

                    <div class="d-flex justify-content-between">
                        {# Bouton suppression intégré en bas à gauche pour cohérence #}
                        <button type="button" class="btn btn-outline-danger" data-toggle="modal" data-target="#deleteModal">
                            <i class="fas fa-trash mr-1"></i> Supprimer ce créneau
                        </button>

                        <div class="d-flex">
                            <a href="{{ path('medecin_disponibilite_index') }}" class="btn btn-secondary mr-2">
                                <i class="fas fa-times mr-1"></i> Annuler
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save mr-1"></i> Mettre à jour
                            </button>
                        </div>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>

</div>

{# Modal de suppression séparée pour propreté #}
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel"><i class="fas fa-exclamation-triangle mr-2"></i>Confirmation de suppression</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                Êtes-vous sûr de vouloir supprimer définitivement ce créneau ? Cette action est irréversible.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                <form method="post" action="{{ path('medecin_disponibilite_delete', {id: disponibilite.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ disponibilite.id) }}">
                    <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
