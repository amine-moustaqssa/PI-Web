{% extends 'front/medecin/base_medecin.html.twig' %}

{% block title %}Mes Disponibilités | Clinic360{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# Page Heading #}
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-clock mr-2"></i>Mes Disponibilités</h1>
        <a href="{{ path('medecin_disponibilite_new') }}" class="d-none d-sm-inline-block btn btn-sm btn-success shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50 mr-1"></i> Ajouter un créneau
        </a>
    </div>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Table Card #}
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Créneaux horaires</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle" id="dispoTable" width="100%" cellspacing="0">
                    <thead class="bg-light">
                        <tr>
                            <th>Jour</th>
                            <th>Début</th>
                            <th>Fin</th>
                            <th class="text-center">Récurrence</th>
                            <th class="text-center" style="width: 15%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for dispo in disponibilites %}
                        <tr>
                            <td class="font-weight-bold">
                                {% set jours = {1: 'Lundi', 2: 'Mardi', 3: 'Mercredi', 4: 'Jeudi', 5: 'Vendredi', 6: 'Samedi', 7: 'Dimanche'} %}
                                {{ jours[dispo.jourSemaine] | default('Jour ' ~ dispo.jourSemaine) }}
                            </td>
                            <td>
                                <i class="fas fa-play text-success mr-1 small"></i>
                                {{ dispo.heureDebut ? dispo.heureDebut|date('H:i') : '—' }}
                            </td>
                            <td>
                                <i class="fas fa-stop text-danger mr-1 small"></i>
                                {{ dispo.heureFin ? dispo.heureFin|date('H:i') : '—' }}
                            </td>
                            <td class="text-center">
                                {% if dispo.estRecurrent %}
                                    <span class="badge badge-success px-3 py-2"><i class="fas fa-redo mr-1"></i>Hebdomadaire</span>
                                {% else %}
                                    <span class="badge badge-secondary px-3 py-2">Ponctuel</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                <a href="{{ path('medecin_disponibilite_show', {id: dispo.id}) }}" class="btn btn-info btn-circle btn-sm" title="Voir">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('medecin_disponibilite_edit', {id: dispo.id}) }}" class="btn btn-warning btn-circle btn-sm" title="Modifier">
                                    <i class="fas fa-pen"></i>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="fas fa-calendar-times fa-3x text-gray-300 mb-3 d-block"></i>
                                <h6 class="text-gray-500">Aucun créneau de disponibilité</h6>
                                <a href="{{ path('medecin_disponibilite_new') }}" class="btn btn-success btn-sm mt-2">
                                    <i class="fas fa-plus mr-1"></i> Ajouter un créneau
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof $ !== 'undefined' && $.fn.DataTable) {
            $('#dispoTable').DataTable({
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json"
                },
                pageLength: 10,
                order: [[0, 'asc'], [1, 'asc']]
            });
        }
    });
</script>
{% endblock %}
