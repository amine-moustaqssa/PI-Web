{% extends 'front/medecin/base_medecin.html.twig' %}

{% block title %}Nouveau créneau | Clinic360{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# Page Heading #}
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-plus-circle mr-2"></i>Nouveau créneau</h1>
        <a href="{{ path('medecin_disponibilite_index') }}" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm">
            <i class="fas fa-arrow-left fa-sm text-white-50 mr-1"></i> Retour à la liste
        </a>
    </div>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-calendar-plus mr-1"></i> Définir un créneau de disponibilité
                    </h6>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

                    <div class="form-group">
                        <label class="font-weight-bold text-gray-700">
                            <i class="fas fa-calendar-day mr-1 text-primary"></i> Jour de la semaine
                        </label>
                        {{ form_widget(form.jourSemaine, {'attr': {'class': 'form-control'}}) }}
                        <div class="text-danger small mt-1">{{ form_errors(form.jourSemaine) }}</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold text-gray-700">
                                    <i class="fas fa-play text-success mr-1"></i> Heure de début
                                </label>
                                {{ form_widget(form.heureDebut, {'attr': {'class': 'form-control'}}) }}
                                <div class="text-danger small mt-1">{{ form_errors(form.heureDebut) }}</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold text-gray-700">
                                    <i class="fas fa-stop text-danger mr-1"></i> Heure de fin
                                </label>
                                {{ form_widget(form.heureFin, {'attr': {'class': 'form-control'}}) }}
                                <div class="text-danger small mt-1">{{ form_errors(form.heureFin) }}</div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="custom-control custom-switch">
                            {{ form_widget(form.estRecurrent, {'attr': {'class': 'custom-control-input', 'id': 'estRecurrent'}}) }}
                            <label class="custom-control-label font-weight-bold text-gray-700" for="estRecurrent">
                                <i class="fas fa-redo mr-1 text-info"></i> Créneau récurrent (hebdomadaire)
                            </label>
                        </div>
                        <div class="text-danger small mt-1">{{ form_errors(form.estRecurrent) }}</div>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-end">
                        <a href="{{ path('medecin_disponibilite_index') }}" class="btn btn-light mr-2">Annuler</a>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save mr-1"></i> Enregistrer
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
