{% extends 'front/medecin/base_medecin.html.twig' %}

{% block title %}Dossier Clinique{% endblock %}

{% block body %}
<div class="container-fluid">

    <!-- Titre + bouton retour -->
    <div class="d-flex align-items-center mb-4">
        <a href="{{ path('medecin_profils_list') }}"
           class="btn btn-sm btn-light shadow-sm mr-3"
           title="Retour à la liste">
            <i class="fas fa-arrow-left"></i>
        </a>

        <h1 class="h3 text-gray-800 mb-0">
            Dossier Clinique – {{ profil.nom }} {{ profil.prenom }}
        </h1>
    </div>

    <div class="row">
        <!-- Carte Dossier Clinique -->
        <div class="col-md-8">
            <div class="card shadow mb-4">
                <div class="card-body">
                    {% if dossier %}
                        <p>
                            <strong>Antécédents :</strong><br>
                            {{ dossier.antecedents ?: 'Aucun antécédent enregistré' }}
                        </p>

                        <p>
                            <strong>Allergies :</strong><br>
                            {% if dossier.allergies %}
                                {{ dossier.allergies|join(', ') }}
                            {% else %}
                                Aucune allergie enregistrée
                            {% endif %}
                        </p>

                        <div class="mt-4">
                            <!-- Modifier dossier -->
                            <a href="{{ path('medecin_dossier_edit', { id: profil.id }) }}"
                               class="btn btn-primary">
                                <i class="fas fa-edit"></i> Modifier le dossier
                            </a>

                            <!-- Historique des rapports -->
                            <a href="{{ path('medecin_dossier_rapports', { id: dossier.id }) }}"
                               class="btn btn-info ml-2">
                                <i class="fas fa-history"></i> Historique des rapports
                            </a>
                        </div>
                    {% else %}
                        <div class="alert alert-warning">
                            Ce profil n’a pas encore de dossier clinique.
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Carte Infos Profil -->
        <div class="col-md-4">
            <div class="card shadow mb-4">
                <div class="card-header">
                    <strong>Informations du profil</strong>
                </div>
                <div class="card-body">
                    <p><strong>Nom :</strong> {{ profil.nom }}</p>
                    <p><strong>Prénom :</strong> {{ profil.prenom }}</p>
                    <p><strong>Email :</strong> {{ profil.titulaire ? profil.titulaire.email : 'Non renseigné' }}</p>
                    <p><strong>Âge :</strong>
                        {% if profil.dateNaissance %}
                            {{ (date()|date('Y') - profil.dateNaissance|date('Y')) }}
                        {% else %}
                            Non renseigné
                        {% endif %}
                    </p>
                    <p><strong>Contact d’urgence :</strong> {{ profil.contactUrgence ?: 'Non renseigné' }}</p>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
