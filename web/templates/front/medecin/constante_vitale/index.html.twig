{% extends 'front/medecin/base_medecin.html.twig' %}

{% block title %}Constantes Vitales - Consultation #{{ consultation.id }} | Clinic360{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# Breadcrumb #}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0 m-0">
            <li class="breadcrumb-item"><a href="{{ path('medecin_dashboard', {id: app.user.id}) }}">Tableau de bord</a></li>
            <li class="breadcrumb-item"><a href="{{ path('medecin_consultation_index') }}">Consultations</a></li>
            <li class="breadcrumb-item active">Consultation #{{ consultation.id }} — Constantes</li>
        </ol>
    </nav>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for msg in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show shadow-sm" role="alert">
                {% if label == 'danger' %}
                    <i class="fas fa-exclamation-triangle mr-2"></i>
                {% elseif label == 'warning' %}
                    <i class="fas fa-exclamation-circle mr-2"></i>
                {% endif %}
                <strong>{{ msg }}</strong>
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">
                <i class="fas fa-heartbeat text-danger mr-2"></i>
                Constantes Vitales
            </h1>
            <p class="text-muted small mb-0">
                Consultation #{{ consultation.id }}
                {% if consultation.dateEffectuee %}
                    — {{ consultation.dateEffectuee|date('d/m/Y H:i') }}
                {% endif %}
            </p>
        </div>
        <div>
            {% if consultation.statut == 'en_cours' or consultation.statut == 'en cours' %}
                <span class="badge badge-warning px-3 py-2"><i class="fas fa-spinner mr-1"></i> En cours</span>
            {% elseif consultation.statut == 'terminée' or consultation.statut == 'terminé' %}
                <span class="badge badge-success px-3 py-2"><i class="fas fa-check mr-1"></i> Terminée</span>
            {% elseif consultation.statut == 'planifiée' or consultation.statut == 'planifié' %}
                <span class="badge badge-info px-3 py-2"><i class="fas fa-calendar mr-1"></i> Planifiée</span>
            {% elseif consultation.statut == 'annulée' %}
                <span class="badge badge-danger px-3 py-2"><i class="fas fa-times mr-1"></i> Annulée</span>
            {% else %}
                <span class="badge badge-secondary px-3 py-2">{{ consultation.statut }}</span>
            {% endif %}
        </div>
    </div>

    {# Alert Summary Cards #}
    {% if constantes|length > 0 %}
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body py-2">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Constantes</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ constantes|length }}</div>
                        </div>
                        <div class="col-auto"><i class="fas fa-heartbeat fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body py-2">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Normales</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ analysis.alerts|filter(a => a.level == 'normal')|length }}
                            </div>
                        </div>
                        <div class="col-auto"><i class="fas fa-check-circle fa-2x text-success"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body py-2">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Attention</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ analysis.alerts|filter(a => a.level == 'warning')|length }}
                            </div>
                        </div>
                        <div class="col-auto"><i class="fas fa-exclamation-circle fa-2x text-warning"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-left-danger shadow h-100 py-2">
                <div class="card-body py-2">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Critiques</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ analysis.alerts|filter(a => a.level == 'critical')|length }}
                            </div>
                        </div>
                        <div class="col-auto"><i class="fas fa-exclamation-triangle fa-2x text-danger"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {# Constantes Table (read-only) #}
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex align-items-center">
            <i class="fas fa-list text-primary mr-2"></i>
            <h6 class="m-0 font-weight-bold text-primary">Relevés des constantes</h6>
        </div>
        <div class="card-body">
            {% if constantes|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="thead-light">
                            <tr>
                                <th>Type</th>
                                <th>Valeur</th>
                                <th>Unité</th>
                                <th>Statut</th>
                                <th>Plage normale</th>
                                <th>Date de prise</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for key, constante in constantes %}
                                {% set alert = analysis.alerts[key] ?? null %}
                                {% if alert and alert.level == 'critical' %}
                                    {% set rowClass = 'table-danger' %}
                                {% elseif alert and alert.level == 'warning' %}
                                    {% set rowClass = 'table-warning' %}
                                {% else %}
                                    {% set rowClass = '' %}
                                {% endif %}
                                <tr class="{{ rowClass }}">
                                    <td><span class="font-weight-bold">{{ constante.type }}</span></td>
                                    <td>
                                        <span class="font-weight-bold" style="font-size: 1.1em;">
                                            {{ constante.valeur }}
                                        </span>
                                    </td>
                                    <td>{{ constante.unite }}</td>
                                    <td>
                                        {% if alert %}
                                            <span class="badge badge-{{ alert.badge_class }} px-2 py-1">
                                                <i class="{{ alert.icon }} mr-1"></i>
                                                {{ alert.level == 'normal' ? 'Normal' : (alert.level == 'warning' ? 'Attention' : (alert.level == 'critical' ? 'CRITIQUE' : 'Inconnu')) }}
                                            </span>
                                        {% else %}
                                            <span class="badge badge-secondary px-2 py-1">
                                                <i class="fas fa-question-circle mr-1"></i> Non référencé
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if alert and alert.reference is defined %}
                                            <small class="text-muted">
                                                {{ alert.reference.normal_low }} – {{ alert.reference.normal_high }} {{ alert.reference.unite }}
                                            </small>
                                            <br>
                                            <small class="text-muted font-italic" style="font-size: 0.75em;">
                                                Source : {{ alert.reference.source }}
                                            </small>
                                        {% else %}
                                            <small class="text-muted">—</small>
                                        {% endif %}
                                    </td>
                                    <td>{{ constante.datePrise ? constante.datePrise|date('d/m/Y H:i') : '—' }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {# Medical Reference Legend #}
                <div class="mt-3 p-3 bg-light rounded border">
                    <h6 class="text-gray-700 mb-2"><i class="fas fa-book-medical mr-1"></i> Légende des alertes</h6>
                    <span class="badge badge-success px-2 py-1 mr-2"><i class="fas fa-check-circle mr-1"></i> Normal</span>
                    <span class="badge badge-warning px-2 py-1 mr-2"><i class="fas fa-exclamation-circle mr-1"></i> Attention</span>
                    <span class="badge badge-danger px-2 py-1 mr-2"><i class="fas fa-exclamation-triangle mr-1"></i> Critique</span>
                    <span class="badge badge-secondary px-2 py-1"><i class="fas fa-question-circle mr-1"></i> Non référencé</span>
                    <p class="text-muted small mt-2 mb-0">
                        <i class="fas fa-info-circle mr-1"></i>
                        Les seuils sont basés sur les recommandations OMS, AHA, ESC, ERS, ADA, KDIGO, NICE et HAS.
                        Ces valeurs sont indicatives et doivent être interprétées dans le contexte clinique du patient.
                    </p>
                </div>

            {% else %}
                <div class="text-center py-5">
                    <i class="fas fa-heartbeat fa-3x mb-3 text-gray-300"></i>
                    <p class="text-muted">Aucune constante vitale enregistrée pour cette consultation.</p>
                </div>
            {% endif %}
        </div>
    </div>

    {# Back button #}
    <div class="mt-3">
        <a href="{{ path('medecin_consultation_show', {'id': consultation.id}) }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left mr-1"></i> Retour à la consultation
        </a>
    </div>

</div>
{% endblock %}
