<form method="post" action="{{ path('app_disponibilite_delete', {'id': disponibilite.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');" style="display: inline-block;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ disponibilite.id) }}">
    
    <button class="btn btn-danger btn-icon-split btn-sm shadow-sm">
        <span class="icon text-white-50">
            <i class="fas fa-trash"></i>
        </span>
        <span class="text">Supprimer</span>
    </button>
</form>
