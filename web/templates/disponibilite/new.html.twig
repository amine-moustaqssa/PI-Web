{% extends 'admin/base_admin.html.twig' %}

{% block title %}Nouvelle Disponibilité{% endblock %}

{% block body %}
    {# Holiday error message #}
    {% if holiday_error is defined and holiday_error %}
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            {{ holiday_error }}
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    {% endif %}

    {# 1. En-tête de la page : Titre + Bouton Retour #}
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Créer une nouvelle disponibilité</h1>
        <a href="{{ path('app_disponibilite_index') }}" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm">
            <i class="fas fa-arrow-left fa-sm text-white-50"></i> Retour à la liste
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Formulaire d'ajout</h6>
        </div>
        <div class="card-body">
            {# Inclusion du formulaire #}
            {{ include('disponibilite/_form.html.twig') }}

            <hr class="my-4">

            <div class="d-flex justify-content-end">
                <button type="submit" form="disponibilite_form" class="btn btn-success btn-icon-split btn-sm shadow-sm">
                    <span class="icon text-white-50">
                        <i class="fas fa-check"></i>
                    </span>
                    <span class="text">Enregistrer</span>
                </button>
            </div>
        </div>
    </div>
{% endblock %}