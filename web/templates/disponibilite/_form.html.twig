{{ form_start(form, {'attr': {'class': 'user', 'id': 'disponibilite_form', 'novalidate': 'novalidate'}}) }}
    
    {# Affiche les erreurs globales du formulaire s'il y en a #}
    {{ form_errors(form) }}

    <div class="row">
        {# Champ Date spécifique #}
        <div class="col-md-12">
            <div class="form-group">
                <label class="small mb-1 font-weight-bold text-gray-700">Date de la disponibilité <span class="text-danger">*</span></label>
                <div class="input-group input-group-sm">
                    <div class="input-group-prepend">
                        <span class="input-group-text bg-primary text-white border-0"><i class="fas fa-calendar-alt"></i></span>
                    </div>
                    {{ form_widget(form.dateSpecifique, {'attr': {'class': 'form-control form-control-sm bg-light border-0 small', 'style': 'height: auto; padding: 0.5rem'}}) }}
                </div>
                {{ form_errors(form.dateSpecifique) }}
            </div>
        </div>
    </div>

    <div class="row">
        {# Champ Heure Début #}
        <div class="col-md-6">
            <div class="form-group">
                <label class="small mb-1 font-weight-bold text-gray-700">Heure de Début <span class="text-danger">*</span></label>
                <div class="input-group input-group-sm">
                    <div class="input-group-prepend">
                        <span class="input-group-text bg-success text-white border-0"><i class="fas fa-clock"></i></span>
                    </div>
                    {{ form_widget(form.heureDebut, {'attr': {'class': 'form-control form-control-sm bg-light border-0 small', 'style': 'height: auto; padding: 0.5rem'}}) }}
                </div>
                {{ form_errors(form.heureDebut) }}
            </div>
        </div>

        {# Champ Heure Fin #}
        <div class="col-md-6">
            <div class="form-group">
                <label class="small mb-1 font-weight-bold text-gray-700">Heure de Fin <span class="text-danger">*</span></label>
                <div class="input-group input-group-sm">
                    <div class="input-group-prepend">
                        <span class="input-group-text bg-danger text-white border-0"><i class="fas fa-hourglass-end"></i></span>
                    </div>
                    {{ form_widget(form.heureFin, {'attr': {'class': 'form-control form-control-sm bg-light border-0 small', 'style': 'height: auto; padding: 0.5rem'}}) }}
                </div>
                {{ form_errors(form.heureFin) }}
            </div>
        </div>
    </div>

    <div class="row mt-3">
        {# Champ Récurrence (Standard Checkbox) #}
        <div class="col-md-12">
            <div class="card border-left-info shadow-sm py-2">
                <div class="card-body py-2">
                    <div class="form-check">
                        {{ form_widget(form.estRecurrent, {'attr': {'class': 'form-check-input'}}) }}
                        <label class="form-check-label font-weight-bold text-primary small" for="{{ form.estRecurrent.vars.id }}">
                            <i class="fas fa-sync-alt mr-2"></i> Répéter cette disponibilité chaque semaine ?
                        </label>
                    </div>
                </div>
            </div>
            {{ form_errors(form.estRecurrent) }}
        </div>
    </div>

    {% if form.medecin is defined %}
    <div class="row mt-3">
        <div class="col-md-12">
            <div class="form-group">
                <label class="small mb-1 font-weight-bold text-gray-700">Médecin</label>
                <div class="input-group input-group-sm">
                    <div class="input-group-prepend">
                        <span class="input-group-text bg-info text-white border-0"><i class="fas fa-user-md"></i></span>
                    </div>
                    {{ form_widget(form.medecin, {'attr': {'class': 'form-control form-control-sm bg-light border-0 small', 'style': 'height: auto; padding: 0.5rem'}}) }}
                </div>
                {{ form_errors(form.medecin) }}
            </div>
        </div>
    </div>
    {% endif %}

    <hr class="my-4">

    {# Bouton Enregistrer Stylisé #}

{{ form_end(form) }}
