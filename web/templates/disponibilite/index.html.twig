{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion des Disponibilités{% endblock %}

{% block body %}
    {# 1. En-tête de la page : Titre + Bouton Ajouter #}
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Mes Disponibilités</h1>
        <a href="{{ path('app_disponibilite_new') }}" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50"></i> Ajouter un créneau
        </a>
    </div>

    {# 1.5 Section de Filtrage Avancé #}
    <div class="card shadow mb-4 border-left-primary">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-filter mr-2"></i>Filtrer les disponibilités</h6>
        </div>
        <div class="card-body">
            <form method="get" class="form-row align-items-end">
                {# Filtre par Jour #}
                <div class="col-md-3 mb-3">
                    <label class="small font-weight-bold">Jour de la semaine</label>
                    <select name="jour" class="form-control shadow-sm">
                        <option value="">Tous les jours</option>
                        <option value="1">Lundi</option>
                        <option value="2">Mardi</option>
                        <option value="3">Mercredi</option>
                        <option value="4">Jeudi</option>
                        <option value="5">Vendredi</option>
                        <option value="6">Samedi</option>
                        <option value="7">Dimanche</option>
                    </select>
                </div>

                {# Filtre par Récurrence #}
                <div class="col-md-3 mb-3">
                    <label class="small font-weight-bold">Récurrence</label>
                    <select name="recurrent" class="form-control shadow-sm">
                        <option value="">Toutes</option>
                        <option value="1">Récurrent</option>
                        <option value="0">Ponctuel</option>
                    </select>
                </div>

                {# Boutons d'action #}
                <div class="col-md-4 mb-3">
                    <button type="submit" class="btn btn-primary shadow-sm px-4">
                        <i class="fas fa-search fa-sm mr-2"></i>Rechercher
                    </button>
                    <a href="{{ path('app_disponibilite_index') }}" class="btn btn-light shadow-sm px-3 ml-2">
                        Effacer
                    </a>
                </div>
            </form>
        </div>
    </div>

    {# 2. La Carte (Card) blanche ombrée #}
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Liste des créneaux horaires</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                    <thead class="thead-light">
                        <tr>
                            <th>Jour</th>
                            <th>Début</th>
                            <th>Fin</th>
                            <th>Récurrence</th>
                            <th class="text-center" style="width: 15%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for disponibilite in disponibilites %}
                        <tr>
                            {# Conversion : Numéro du jour -> Nom du jour #}
                            <td class="font-weight-bold">
                                {% if disponibilite.jourSemaine == 1 %}Lundi
                                {% elseif disponibilite.jourSemaine == 2 %}Mardi
                                {% elseif disponibilite.jourSemaine == 3 %}Mercredi
                                {% elseif disponibilite.jourSemaine == 4 %}Jeudi
                                {% elseif disponibilite.jourSemaine == 5 %}Vendredi
                                {% elseif disponibilite.jourSemaine == 6 %}Samedi
                                {% elseif disponibilite.jourSemaine == 7 %}Dimanche
                                {% else %}Jour {{ disponibilite.jourSemaine }}
                                {% endif %}
                            </td>

                            {# Affichage propre des heures (H:i) sans les secondes #}
                            <td>{{ disponibilite.heureDebut ? disponibilite.heureDebut|date('H:i') : '' }}</td>
                            <td>{{ disponibilite.heureFin ? disponibilite.heureFin|date('H:i') : '' }}</td>
                            
                            {# Badge coloré pour la récurrence #}
                            <td>
                                {% if disponibilite.estRecurrent %}
                                    <span class="badge badge-success px-2 py-1">Oui</span>
                                {% else %}
                                    <span class="badge badge-secondary px-2 py-1">Non</span>
                                {% endif %}
                            </td>

                            {# Boutons d'actions avec icônes #}
                            <td class="text-center">
                                <a href="{{ path('app_disponibilite_show', {'id': disponibilite.id}) }}" class="btn btn-info btn-circle btn-sm" title="Voir les détails">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('app_disponibilite_edit', {'id': disponibilite.id}) }}" class="btn btn-warning btn-circle btn-sm" title="Modifier">
                                    <i class="fas fa-pen"></i>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="fas fa-calendar-times fa-2x mb-3"></i><br>
                                Aucun créneau de disponibilité trouvé.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}