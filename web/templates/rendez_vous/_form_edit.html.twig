{# templates/rendez_vous/_form_edit.html.twig #}
{{ form_start(form, {'action': path('app_rendez_vous_edit', {'id': rendezVous.id}), 'attr': {'novalidate': 'novalidate'}}) }}
    
    <div class="row">
        <div class="col-md-6">
            <div class="form-group form-group-modern">
                <label class="form-label-modern">Patient concerné</label>
                {{ form_widget(form.profil, {'attr': {'class': 'form-control form-control-modern'}}) }}
                {{ form_errors(form.profil) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group form-group-modern">
                <label class="form-label-modern">Date et Heure</label>
                {{ form_widget(form.date_debut, {'attr': {'class': 'form-control form-control-modern'}}) }}
                {{ form_errors(form.date_debut) }}
            </div>
        </div>
    </div>

    <div class="form-group form-group-modern">
        <label class="form-label-modern">Motif</label>
        {{ form_widget(form.motif, {'attr': {'class': 'form-control form-control-modern', 'rows': '3'}}) }}
        {{ form_errors(form.motif) }}
    </div>

    <div class="modal-footer border-top-0 px-0 pb-0">
        <button type="button" class="btn btn-ghost-modern" data-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary-modern">Sauvegarder</button>
    </div>

{{ form_end(form) }}