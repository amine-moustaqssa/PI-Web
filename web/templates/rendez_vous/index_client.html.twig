{% extends 'base.html.twig' %}

{% block title %}Mes Rendez-vous{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Modern Modal Styles */
        .modal-content-modern { border: none; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
        .modal-header-modern { border-bottom: none; padding-bottom: 0; background-color: white; border-radius: 12px 12px 0 0; }
        .modal-title-modern { font-weight: 700; color: #1a1f36; font-size: 1.1rem; }
        .form-label-modern { font-size: 0.85rem; font-weight: 600; color: #3c4257; margin-bottom: 6px; display: block; }
        .form-control-modern { border-radius: 6px; border: 1px solid #e3e8ee; padding: 10px 12px; font-size: 0.9rem; color: #1a1f36; width: 100%; }
        .btn-ghost-modern { background: transparent; border: 1px solid #e3e8ee; color: #3c4257; font-weight: 600; border-radius: 6px; padding: 8px 16px; }
        .btn-primary-modern { background-color: #2e3b55; border: none; color: white; font-weight: 600; border-radius: 6px; padding: 8px 20px; }
        
        /* Wizard Cards */
        .spec-card { border: 1px solid #e3e8ee; border-radius: 8px; padding: 15px; cursor: pointer; text-align: center; background: white; transition: all 0.2s; }
        .spec-card:hover { border-color: #2e3b55; background-color: #f7f9fc; transform: translateY(-2px); }
        .spec-icon { font-size: 1.5rem; margin-bottom: 10px; color: #4e73df; }
        .spec-name { font-weight: 600; font-size: 0.9rem; color: #1a1f36; }
        
        .step-section { display: none; }
        .step-section.active { display: block; }
    </style>
{% endblock %}

{% block sidebar %}
    {% include 'titulaire/_partials/_sidebar.html.twig' %}
{% endblock %}

{% block topbar %}{% endblock %}

{% block body %}
    
    <div class="mt-4">
        
        <div class="d-sm-flex align-items-center justify-content-between mb-4">
            <h1 class="h3 mb-0 text-gray-800">Mes Rendez-vous</h1>
            <button class="btn btn-sm btn-primary shadow-sm" data-toggle="modal" data-target="#newRdvModal">
                <i class="fas fa-calendar-plus fa-sm text-white-50 mr-2"></i> Nouveau RDV
            </button>
        </div>

        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Historique et gestion des consultations</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 20%;">Date et Heure</th>
                                <th>Détails / Patient</th>
                                <th class="text-center" style="width: 15%;">Statut</th>
                                <th class="text-center" style="width: 15%;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for rdv in rendez_vous %}
                            <tr>
                                <td class="align-middle">
                                    <div class="font-weight-bold text-gray-800">{{ rdv.dateDebut|date('d/m/Y') }}</div>
                                    <div class="small text-muted"><i class="far fa-clock mr-1"></i>{{ rdv.dateDebut|date('H:i') }}</div>
                                </td>
                                <td class="align-middle"><span class="text-dark">{{ rdv.type }}</span></td>
                                <td class="text-center align-middle">
                                    {% if rdv.statut in ['en attente de confirmation', 'En attente'] %}
                                        <span class="badge badge-warning px-2 py-1">En attente</span>
                                    {% elseif rdv.statut in ['annulé', 'Annulé'] %}
                                        <span class="badge badge-danger px-2 py-1">Annulé</span>
                                    {% elseif rdv.statut in ['confirmé', 'Confirmé'] %}
                                        <span class="badge badge-success px-2 py-1">Confirmé</span>
                                    {% else %}
                                        <span class="badge badge-secondary px-2 py-1">{{ rdv.statut }}</span>
                                    {% endif %}
                                </td>
                                <td class="text-center align-middle">
                                    {% if rdv.statut not in ['annulé', 'Annulé'] %}
                                        <button class="btn btn-primary btn-circle btn-sm btn-edit-rdv" 
                                                data-url="{{ path('app_rendez_vous_edit', {'id': rdv.id}) }}"
                                                title="Modifier">
                                            <i class="fas fa-pen"></i>
                                        </button>
                                        <a href="{{ path('app_rendez_vous_cancel', {'id': rdv.id}) }}" 
                                           class="btn btn-danger btn-circle btn-sm ml-1"
                                           onclick="return confirm('Voulez-vous vraiment annuler ?');" title="Annuler">
                                            <i class="fas fa-times"></i>
                                        </a>
                                    {% else %}
                                        <span class="small text-gray-500">-</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <h6 class="text-gray-600">Aucun rendez-vous trouvé</h6>
                                    <button class="btn btn-primary btn-sm mt-3" data-toggle="modal" data-target="#newRdvModal">Prendre un rendez-vous</button>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="newRdvModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content modal-content-modern">
                <div class="modal-header modal-header-modern">
                    <div>
                        <h5 class="modal-title modal-title-modern">Prendre un Rendez-vous</h5>
                        <p class="modal-subtitle" id="rdvModalSubtitle">Étape 1 : Choisissez une spécialité</p>
                    </div>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body pt-4">
                    <div id="step-specialite" class="step-section active">
                        <div class="row">
                            {% if specialites is defined %}
                                {% for spec in specialites %}
                                    <div class="col-md-4 mb-3">
                                        <div class="spec-card" onclick="selectSpecialty({{ spec.id }}, '{{ spec.nom }}')">
                                            <div class="spec-icon"><i class="fas fa-stethoscope"></i></div>
                                            <div class="spec-name">{{ spec.nom }}</div>
                                        </div>
                                    </div>
                                {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                    <div id="step-form" class="step-section">
                        {% if form is defined %}
                            {{ form_start(form) }}
                                <input type="hidden" name="specialite_id" id="selected_specialite_id">
                                <div class="alert alert-info border-0 bg-light-primary text-primary small mb-4">
                                    <i class="fas fa-info-circle mr-1"></i> Réservation pour : <strong id="selected_spec_name">...</strong>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group mb-3">
                                            <label class="form-label-modern">Patient concerné</label>
                                            {{ form_widget(form.profil, {'attr': {'class': 'form-control form-control-modern'}}) }}
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group mb-3">
                                            <label class="form-label-modern">Date et Heure</label>
                                            {{ form_widget(form.date_debut, {'attr': {'class': 'form-control form-control-modern'}}) }}
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group mb-3">
                                    <label class="form-label-modern">Motif</label>
                                    {{ form_widget(form.motif, {'attr': {'class': 'form-control form-control-modern', 'rows': '3'}}) }}
                                </div>
                                {{ form_rest(form) }}
                                <div class="modal-footer border-top-0 px-0 pb-0">
                                    <button type="button" class="btn btn-ghost-modern" onclick="goBackToStep1()">Retour</button>
                                    <button type="submit" class="btn btn-primary-modern">Confirmer</button>
                                </div>
                            {{ form_end(form) }}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editRdvModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content modal-content-modern">
                <div class="modal-header modal-header-modern">
                    <h5 class="modal-title modal-title-modern">Modifier le Rendez-vous</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body pt-4" id="editRdvModalBody">
                    </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function() {
            // New RDV Error Handling
            if ($('#newRdvModal').find('.is-invalid, .invalid-feedback').length > 0) {
                $('#newRdvModal').modal('show');
                $('#step-specialite').removeClass('active');
                $('#step-form').addClass('active');
            }

            // --- EDIT BUTTON LOGIC ---
            $('.btn-edit-rdv').on('click', function(e) {
                e.preventDefault();
                var url = $(this).data('url');

                $('#editRdvModal').modal('show');
                $('#editRdvModalBody').html('<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>');

                $.ajax({
                    url: url,
                    type: 'GET',
                    // This Header is Vital for Symfony to treat this as AJAX
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    success: function(response) {
                        $('#editRdvModalBody').html(response);
                    },
                    error: function() {
                        $('#editRdvModalBody').html('<div class="alert alert-danger">Erreur de chargement</div>');
                    }
                });
            });
        });

        function selectSpecialty(id, name) {
            document.getElementById('selected_specialite_id').value = id;
            document.getElementById('selected_spec_name').innerText = name;
            $('#step-specialite').fadeOut(200, function() {
                $('#step-specialite').removeClass('active');
                $('#step-form').fadeIn(200).addClass('active');
            });
        }

        function goBackToStep1() {
            $('#step-form').fadeOut(200, function() {
                $('#step-form').removeClass('active');
                $('#step-specialite').fadeIn(200).addClass('active');
            });
        }
    </script>
{% endblock %}