<div class="modal-header modal-header-modern d-flex justify-content-between align-items-start">
    <div>
        <h5 class="modal-title-modern">Modifier le Rendez-vous</h5>
        <p class="modal-subtitle">Mettez à jour les informations ci-dessous.</p>
    </div>
    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>

<div class="modal-body pt-4">
    {# --- CORRECTION MAJEURE ICI --- #}
    {# On force l'action vers la route d'édition, sinon ça repart vers la création #}
    {{ form_start(form, {'action': path('app_rendez_vous_edit', {'id': rendezVous.id})}) }}
    
        <div class="form-group-modern">
            <label class="form-label-modern">Patient concerné <span class="required-star">*</span></label>
            {{ form_widget(form.profil, {'attr': {'class': 'form-control form-control-modern'}}) }}
        </div>

        <div class="form-group-modern">
            <label class="form-label-modern">Date et Heure <span class="required-star">*</span></label>
            {{ form_widget(form.date_debut, {'attr': {'class': 'form-control form-control-modern'}}) }}
        </div>

        <div class="form-group-modern">
            <label class="form-label-modern">Motif</label>
            {{ form_widget(form.motif, {'attr': {'class': 'form-control form-control-modern', 'rows': '4'}}) }}
        </div>

        {{ form_rest(form) }}

        <div class="modal-footer border-top pt-4 px-0">
            <button type="button" class="btn btn-ghost-modern" data-dismiss="modal">Annuler</button>
            <button type="submit" class="btn btn-primary-modern">
                <i class="fas fa-lock mr-2"></i> Enregistrer
            </button>
        </div>
    {{ form_end(form) }}
</div>

<style>
    .required-star { color: #e51c00; }
    .form-label-modern { font-size: 0.85rem; font-weight: 600; color: #3c4257; margin-bottom: 6px; display: block; }
    .form-group-modern { margin-bottom: 1.25rem; }
    .form-control-modern { 
        border-radius: 6px; 
        border: 1px solid #e3e8ee; 
        padding: 10px 12px; 
        font-size: 0.9rem; 
        color: #1a1f36; 
        transition: all 0.2s; 
        width: 100%; 
    }
    .form-control-modern:focus { border-color: #3c4257; box-shadow: 0 0 0 2px rgba(60, 66, 87, 0.1); }
    .btn-ghost-modern { 
        background: transparent; 
        border: 1px solid #e3e8ee; 
        color: #3c4257; 
        font-weight: 600; 
        border-radius: 6px; 
        padding: 8px 16px; 
    }
    .btn-ghost-modern:hover { background: #f7f9fc; color: #3c4257; text-decoration: none; }
    .btn-primary-modern { 
        background-color: #2e3b55; 
        border: none; 
        color: white; 
        font-weight: 600; 
        border-radius: 6px; 
        padding: 8px 20px; 
        box-shadow: 0 2px 5px rgba(0,0,0,0.1); 
    }
    .btn-primary-modern:hover { background-color: #1a1f36; color: white; }
    .modal-header-modern { 
        border-bottom: none; 
        padding-bottom: 0; 
        background-color: transparent; 
    }
    .modal-title-modern { font-weight: 700; color: #1a1f36; font-size: 1.1rem; }
    .modal-subtitle { font-size: 0.85rem; color: #697386; margin-top: 4px; }
</style>