{% extends 'base.html.twig' %}

{% block body %}
<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Prendre un rendez-vous</h1>
    <p class="mb-4">Étape 1 : Choisissez une spécialité</p>

    <div class="row">
        {% for spec in specialites %}
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-primary shadow h-100 py-2" style="border-left-color: {{ spec.couleur }} !important;">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1" style="color: {{ spec.couleur }} !important;">
                                    {{ spec.nom }}
                                </div>
                                <div class="mb-0 font-weight-bold text-gray-800">
                                    Consultez nos experts en {{ spec.nom }}.
                                </div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-user-md fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0">
                        <a href="{{ path('app_rendez_vous_new', {'specialite': spec.id}) }}" class="btn btn-primary btn-sm btn-block shadow-sm">
                            Sélectionner
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}