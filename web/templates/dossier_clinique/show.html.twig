<h1>Dossier Clinique de {{ profil.nom }} {{ profil.prenom }}</h1>

{% if dossier %}
    <p>
        <strong>Antécédents :</strong>
        {{ dossier.antecedents ?: 'Aucun antécédent enregistré' }}
    </p>

    <p>
        <strong>Allergies :</strong>
        {% if dossier.allergies %}
            {{ dossier.allergies|join(', ') }}
        {% else %}
            Aucune allergie enregistrée
        {% endif %}
    </p>

    <a href="{{ path('dossier_edit', {'id': profil.id}) }}">
        Modifier le dossier
    </a>
{% else %}
    <p>Ce profil n’a pas encore de dossier clinique.</p>

    <a href="{{ path('dossier_edit', {'id': profil.id}) }}">
        Créer le dossier clinique
    </a>
{% endif %}

