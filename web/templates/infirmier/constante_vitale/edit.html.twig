{% extends 'base.html.twig' %}

{% block title %}{{ form.vars.value.id ? 'Modifier' : 'Ajouter' }} Constante{% endblock %}

{% block body %}
<h1>{{ form.vars.value.id ? 'Modifier' : 'Ajouter' }} une Constante Vitale</h1>

{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
{{ form_widget(form) }}
<button class="btn btn-primary">{{ form.vars.value.id ? 'Modifier' : 'Ajouter' }}</button>
{{ form_end(form) }}

<a href="{{ path('infirmier_constante_index', {'id': consultation.id}) }}" class="btn btn-secondary mt-2">Retour à la liste</a>
{% endblock %}
