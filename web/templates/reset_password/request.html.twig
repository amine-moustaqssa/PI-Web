{% extends 'front/base_front.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container px-5">
        <div class="row justify-content-center">
            <div class="col-lg-5">
                <div class="card border-0 shadow rounded-3 overflow-hidden">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="mb-3">
                                <i class="bi bi-key" style="font-size: 3rem; color: #4e73df;"></i>
                            </div>
                            <h2 class="fw-bolder">Mot de passe oublié ?</h2>
                            <p class="text-muted">
                                Entrez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.
                            </p>
                        </div>

                        {% for flash_message in app.flashes('reset_error') %}
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                {{ flash_message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endfor %}

                        {{ form_start(requestForm, {'attr': {'novalidate': 'novalidate'}}) }}
                            <div class="mb-4">
                                <label for="{{ requestForm.email.vars.id }}" class="form-label fw-semibold">Adresse email</label>
                                {{ form_widget(requestForm.email) }}
                                {{ form_errors(requestForm.email) }}
                            </div>

                            <div class="d-grid">
                                <button class="btn btn-primary btn-lg" type="submit">
                                    <i class="bi bi-envelope me-2"></i>Envoyer le lien
                                </button>
                            </div>
                        {{ form_end(requestForm) }}

                        <div class="text-center mt-4">
                            <a href="{{ path('app_login') }}" class="small text-decoration-none">
                                <i class="bi bi-arrow-left me-1"></i>Retour à la connexion
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
