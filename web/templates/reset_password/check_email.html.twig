{% extends 'front/base_front.html.twig' %}

{% block title %}Email envoyé{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container px-5">
        <div class="row justify-content-center">
            <div class="col-lg-5">
                <div class="card border-0 shadow rounded-3 overflow-hidden">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="mb-3">
                                <i class="bi bi-envelope-check" style="font-size: 3rem; color: #1cc88a;"></i>
                            </div>
                            <h2 class="fw-bolder">Vérifiez votre boîte mail</h2>
                            <p class="text-muted">
                                Si un compte existe avec cette adresse, un email contenant un lien de réinitialisation vient d'être envoyé.
                            </p>
                        </div>

                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            Le lien expire dans <strong>{{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}</strong>.
                        </div>

                        <p class="text-muted small text-center">
                            Si vous ne recevez pas l'email, vérifiez votre dossier spam ou 
                            <a href="{{ path('app_forgot_password_request') }}">essayez à nouveau</a>.
                        </p>

                        <div class="text-center mt-4">
                            <a href="{{ path('app_login') }}" class="small text-decoration-none">
                                <i class="bi bi-arrow-left me-1"></i>Retour à la connexion
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
