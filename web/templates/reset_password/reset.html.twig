{% extends 'front/base_front.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container px-5">
        <div class="row justify-content-center">
            <div class="col-lg-5">
                <div class="card border-0 shadow rounded-3 overflow-hidden">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="mb-3">
                                <i class="bi bi-shield-lock" style="font-size: 3rem; color: #4e73df;"></i>
                            </div>
                            <h2 class="fw-bolder">Nouveau mot de passe</h2>
                            <p class="text-muted">Choisissez un nouveau mot de passe sécurisé pour votre compte.</p>
                        </div>

                        {% for flash_message in app.flashes('reset_error') %}
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                {{ flash_message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endfor %}

                        {{ form_start(resetForm, {'attr': {'novalidate': 'novalidate'}}) }}
                            <div class="mb-3">
                                {{ form_label(resetForm.plainPassword.first) }}
                                {{ form_widget(resetForm.plainPassword.first, {'attr': {'placeholder': '••••••••'}}) }}
                                {{ form_errors(resetForm.plainPassword.first) }}
                            </div>

                            <div class="mb-4">
                                {{ form_label(resetForm.plainPassword.second) }}
                                {{ form_widget(resetForm.plainPassword.second, {'attr': {'placeholder': '••••••••'}}) }}
                                {{ form_errors(resetForm.plainPassword.second) }}
                                {{ form_errors(resetForm.plainPassword) }}
                            </div>

                            <div class="d-grid">
                                <button class="btn btn-primary btn-lg" type="submit">
                                    <i class="bi bi-check-circle me-2"></i>Réinitialiser le mot de passe
                                </button>
                            </div>
                        {{ form_end(resetForm) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
