{# src/FacturePdfBundle/Resources/views/facture_pdf.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; font-size: 12px; color: #333; }
        h1   { color: #2c3e50; border-bottom: 2px solid #3498db; padding-bottom: 8px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th { background: #3498db; color: white; padding: 10px; text-align: left; }
        td { padding: 8px 10px; border-bottom: 1px solid #eee; }
        tr:nth-child(even) { background: #f8f9fa; }
        .badge-payee    { background:#27ae60; color:white; padding:2px 8px; border-radius:4px; }
        .badge-en_attente { background:#f39c12; color:white; padding:2px 8px; border-radius:4px; }
        .badge-annulee  { background:#e74c3c; color:white; padding:2px 8px; border-radius:4px; }
        .footer { margin-top: 30px; font-size: 10px; color: #888; text-align: center; }
    </style>
</head>
<body>
    <h1>📄 Rapport des Factures</h1>
    <p>Généré le : {{ generated_at|date('d/m/Y à H:i') }}</p>

    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Référence</th>
                <th>Titulaire</th>
                <th>Montant Total</th>
                <th>Statut</th>
                <th>Consultation ID</th>
            </tr>
        </thead>
        <tbody>
            {% for facture in factures %}
            <tr>
                <td>{{ facture.id }}</td>
                <td><strong>{{ facture.reference }}</strong></td>
                <td>{{ facture.titulaire.nom ?? 'N/A' }} {{ facture.titulaire.prenom ?? '' }}</td>
                <td>{{ facture.montantTotal|number_format(2, ',', ' ') }} TND</td>
                <td>
                    <span class="badge-{{ facture.statut|lower }}">
                        {{ facture.statut }}
                    </span>
                </td>
                <td>{{ facture.consultation.id ?? 'N/A' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="footer">
        Clinique — Rapport généré automatiquement — {{ generated_at|date('Y') }}
    </div>
</body>
</html>